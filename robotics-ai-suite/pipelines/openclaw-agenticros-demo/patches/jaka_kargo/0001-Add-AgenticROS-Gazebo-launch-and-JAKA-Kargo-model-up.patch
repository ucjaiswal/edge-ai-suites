index 0000000..83c4550
--- /dev/null
+++ b/jaka_kargo_ros2/src/jaka_kargo_description/launch/spawn_jaka_kargo_gazebo.launch.py
@@ -0,0 +1,263 @@
+from pathlib import Path
+import re
+
+from ament_index_python.packages import get_package_share_directory
+from launch import LaunchDescription
+from launch.actions import DeclareLaunchArgument, OpaqueFunction
+from launch.conditions import IfCondition
+from launch.substitutions import LaunchConfiguration
+from launch_ros.actions import Node
+
+
+def _launch_setup(context, *args, **kwargs):
+    package_share = Path(get_package_share_directory("jaka_kargo_description"))
+    urdf_path = package_share / "urdf" / "jaka_kargo.urdf"
+
+    if not urdf_path.exists():
+        raise RuntimeError(
+            "JAKA URDF not found at expected path: "
+            f"{urdf_path}"
+        )
+
+    robot_description = urdf_path.read_text(encoding="utf-8")
+    package_uri_prefix = "package://jaka_kargo_description/"
+    model_uri_prefix = "model://jaka_kargo_description/"
+    absolute_prefix = f"file://{package_share.as_posix()}/"
+    robot_description = robot_description.replace(package_uri_prefix, absolute_prefix)
+    robot_description = robot_description.replace(model_uri_prefix, absolute_prefix)
+    disable_gazebo_sensors = LaunchConfiguration("disable_gazebo_sensors").perform(context).strip().lower() == "true"
+    if disable_gazebo_sensors:
+        sensor_links = [
+            "camera_1_link",
+            "camera_2_link",
+            "radar_3d_link",
+            "radar_l_link",
+            "radar_r_link",
+        ]
+        for sensor_link in sensor_links:
+            robot_description = re.sub(
+                rf'\s*<gazebo reference="{sensor_link}">.*?</gazebo>',
+                "",
+                robot_description,
+                flags=re.DOTALL,
+            )
+
+    robot_name = LaunchConfiguration("robot_name").perform(context)
+    x_pose = LaunchConfiguration("x_pose").perform(context)
+    y_pose = LaunchConfiguration("y_pose").perform(context)
+    z_pose = LaunchConfiguration("z_pose").perform(context)
+    use_sim_time = LaunchConfiguration("use_sim_time")
+    use_sensor_bridges = LaunchConfiguration("use_sensor_bridges")
+    joint_state_gz_topic = LaunchConfiguration("joint_state_gz_topic").perform(context).strip()
+    camera_width = LaunchConfiguration("camera_width").perform(context).strip()
+    camera_height = LaunchConfiguration("camera_height").perform(context).strip()
+    camera_update_rate = LaunchConfiguration("camera_update_rate").perform(context).strip()
+    enable_camera_2 = LaunchConfiguration("enable_camera_2").perform(context).strip().lower() == "true"
+    lidar_update_rate = LaunchConfiguration("lidar_update_rate").perform(context).strip()
+
+    for sensor_name in ["camera_1_sensor", "camera_2_sensor"]:
+        robot_description = re.sub(
+            rf'(<sensor name="{sensor_name}" type="camera">[\\s\\S]*?<update_rate>)([^<]+)(</update_rate>)',
+            rf"\\g<1>{camera_update_rate}\\g<3>",
+            robot_description,
+            count=1,
+        )
+        robot_description = re.sub(
+            rf'(<sensor name="{sensor_name}" type="camera">[\\s\\S]*?<width>)([^<]+)(</width>)',
+            rf"\\g<1>{camera_width}\\g<3>",
+            robot_description,
+            count=1,
+        )
+        robot_description = re.sub(
+            rf'(<sensor name="{sensor_name}" type="camera">[\\s\\S]*?<height>)([^<]+)(</height>)',
+            rf"\\g<1>{camera_height}\\g<3>",
+            robot_description,
+            count=1,
+        )
+
+    for lidar_sensor in ["radar_3d_sensor", "radar_l_sensor", "radar_r_sensor"]:
+        robot_description = re.sub(
+            rf'(<sensor name="{lidar_sensor}" type="(?:gpu_lidar|lidar)">[\\s\\S]*?<update_rate>)([^<]+)(</update_rate>)',
+            rf"\\g<1>{lidar_update_rate}\\g<3>",
+            robot_description,
+            count=1,
+        )
+
+    if not enable_camera_2:
+        robot_description = re.sub(
+            r'\s*<gazebo reference="camera_2_link">[\s\S]*?</gazebo>',
+            "",
+            robot_description,
+            count=1,
+        )
+
+    controlled_joint_names = [
+        "agv_x",
+        "agv_y",
+        "agv_yaw",
+        "body_j1",
+        "body_j2",
+        "body_j3",
+        "body_j4",
+        "arm_lj1",
+        "arm_lj2",
+        "arm_lj3",
+        "arm_lj4",
+        "arm_lj5",
+        "arm_lj6",
+        "arm_lj7",
+        "arm_rj1",
+        "arm_rj2",
+        "arm_rj3",
+        "arm_rj4",
+        "arm_rj5",
+        "arm_rj6",
+        "arm_rj7",
+    ]
+    joint_cmd_bridges = [
+        f"/jaka_cargo/joints/{joint_name}/cmd_pos@std_msgs/msg/Float64@gz.msgs.Double"
+        for joint_name in controlled_joint_names
+    ]
+    joint_state_bridge = f"{joint_state_gz_topic}@sensor_msgs/msg/JointState@gz.msgs.Model"
+
+    image_topics = ["/jaka_cargo/sensors/camera_1/image"]
+    image_remaps = [
+        ("/jaka_cargo/sensors/camera_1/image", "/camera_1/image_raw"),
+    ]
+    if enable_camera_2:
+        image_topics.append("/jaka_cargo/sensors/camera_2/image")
+        image_remaps.append(("/jaka_cargo/sensors/camera_2/image", "/camera_2/image_raw"))
+
+    return [
+        Node(
+            package="robot_state_publisher",
+            executable="robot_state_publisher",
+            name="robot_state_publisher",
+            output="screen",
+            parameters=[
+                {
+                    "use_sim_time": use_sim_time,
+                    "robot_description": robot_description,
+                }
+            ],
+        ),
+        Node(
+            package="ros_gz_sim",
+            executable="create",
+            output="screen",
+            arguments=[
+                "-name",
+                robot_name,
+                "-topic",
+                "robot_description",
+                "-x",
+                x_pose,
+                "-y",
+                y_pose,
+                "-z",
+                z_pose,
+            ],
+        ),
+        Node(
+            package="ros_gz_bridge",
+            executable="parameter_bridge",
+            name="jaka_gz_bridge",
+            output="screen",
+            arguments=[
+                "/clock@rosgraph_msgs/msg/Clock@gz.msgs.Clock",
+                joint_state_bridge,
+                "/jaka_cargo/sensors/radar_l/scan@sensor_msgs/msg/LaserScan@gz.msgs.LaserScan",
+                "/jaka_cargo/sensors/radar_r/scan@sensor_msgs/msg/LaserScan@gz.msgs.LaserScan",
+                "/jaka_cargo/sensors/radar_3d/points@sensor_msgs/msg/PointCloud2@gz.msgs.PointCloudPacked",
+            ] + joint_cmd_bridges,
+            remappings=[
+                (joint_state_gz_topic, "/joint_states"),
+                ("/jaka_cargo/sensors/radar_l/scan", "/scan_left"),
+                ("/jaka_cargo/sensors/radar_r/scan", "/scan_right"),
+                ("/jaka_cargo/sensors/radar_3d/points", "/lidar/points"),
+            ],
+            condition=IfCondition(use_sensor_bridges),
+        ),
+        Node(
+            package="ros_gz_image",
+            executable="image_bridge",
+            name="jaka_camera_bridge",
+            output="screen",
+            arguments=image_topics,
+            remappings=image_remaps,
+            condition=IfCondition(use_sensor_bridges),
+        ),
+    ]
+
+
+def generate_launch_description():
+    return LaunchDescription(
+        [
+            DeclareLaunchArgument(
+                "robot_name",
+                default_value="jaka_kargo",
+                description="Entity name used when spawning the JAKA Kargo model.",
+            ),
+            DeclareLaunchArgument(
+                "x_pose",
+                default_value="0.0",
+                description="Initial x position in world frame.",
+            ),
+            DeclareLaunchArgument(
+                "y_pose",
+                default_value="0.0",
+                description="Initial y position in world frame.",
+            ),
+            DeclareLaunchArgument(
+                "z_pose",
+                default_value="0.32",
+                description="Initial z position in world frame.",
+            ),
+            DeclareLaunchArgument(
+                "use_sensor_bridges",
+                default_value="true",
+                description="Start ROS-Gazebo bridges for camera/lidar/odometry topics.",
+            ),
+            DeclareLaunchArgument(
+                "disable_gazebo_sensors",
+                default_value="false",
+                description="Remove Gazebo camera/lidar sensor blocks from the spawned JAKA URDF to reduce rendering load.",
+            ),
+            DeclareLaunchArgument(
+                "use_sim_time",
+                default_value="true",
+                description="Use simulation clock from Gazebo.",
+            ),
+            DeclareLaunchArgument(
+                "joint_state_gz_topic",
+                default_value="/world/default/model/jaka_kargo/joint_state",
+                description="Gazebo joint_state topic for the spawned robot, bridged into ROS /joint_states.",
+            ),
+            DeclareLaunchArgument(
+                "camera_width",
+                default_value="1280",
+                description="Camera image width applied to JAKA camera sensors at spawn time.",
+            ),
+            DeclareLaunchArgument(
+                "camera_height",
+                default_value="720",
+                description="Camera image height applied to JAKA camera sensors at spawn time.",
+            ),
+            DeclareLaunchArgument(
+                "camera_update_rate",
+                default_value="20",
+                description="Camera update rate (Hz) applied to JAKA camera sensors at spawn time.",
+            ),
+            DeclareLaunchArgument(
+                "enable_camera_2",
+                default_value="true",
+                description="Enable second camera sensor and ROS bridge topic /camera_2/image_raw.",
+            ),
+            DeclareLaunchArgument(
+                "lidar_update_rate",
+                default_value="10",
+                description="Lidar update rate (Hz) applied to JAKA lidar sensors at spawn time.",
+            ),
+            OpaqueFunction(function=_launch_setup),
+        ]
+    )
