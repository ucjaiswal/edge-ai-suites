+    if (event.toolName === "ros2_cmd_vel") {
+      const linearX = Number(event.params["linear_x"] ?? 0);
+      const angularZ = Number(event.params["angular_z"] ?? 0);
+      if (Math.abs(linearX) > safety.maxLinearVelocity) {
+        api.logger.warn(`Blocked ros2_cmd_vel: linear velocity ${linearX} exceeds limit ${safety.maxLinearVelocity}`);
+        return {
+          block: true,
+          blockReason: `Linear velocity ${linearX.toFixed(2)} m/s exceeds safety limit of ${safety.maxLinearVelocity} m/s`,
