+            `ros2_cmd_vel: auto-stop fired topic=${topic} scheduled_due_at=${new Date(dueAtMs).toISOString()} fired_at=${new Date().toISOString()}`,
+          );
+          stopMotion(topic, api.logger, "auto-timeout");
+          if (resolveClosedLoop) {
+            resolveClosedLoop({ mode: useClosedLoopAngle ? "angle" : "distance", reached: false, timeout: true, achieved_deg: 0, achieved_m: 0 });
+            resolveClosedLoop = null;
+          }
+        }, timeoutMs);
+
+        const active: ActiveMotion = { intervalId, timeoutId };
+
+        if (useClosedLoopAngle) {
+          let lastYaw: number | null = null;
+          let accumulated = 0;
+          const targetRad = (angleDeg * Math.PI) / 180;
+          const directionSign = angularZ >= 0 ? 1 : -1;
+          const transport = getTransport();
+          const odomSub = transport.subscribe(
+            { topic: odomTopic, type: ODOM_TYPE },
+            (msg: Record<string, unknown>) => {
+              const yaw = yawFromQuaternion(msg);
+              if (yaw == null) return;
+              if (lastYaw == null) {
+                lastYaw = yaw;
+                return;
+              }
+              const delta = normalizeAngleRad(yaw - lastYaw);
+              lastYaw = yaw;
+              accumulated += delta;
+              const progressed = accumulated * directionSign;
+              if (progressed >= targetRad) {
+                const achievedDeg = Math.abs(progressed * 180 / Math.PI);
+                api.logger.info(
+                  `ros2_cmd_vel: closed-loop angle reached topic=${topic} odom_topic=${odomTopic} target_deg=${angleDeg.toFixed(1)} achieved_deg=${achievedDeg.toFixed(1)} at=${new Date().toISOString()}`,
+                );
+                stopMotion(topic, api.logger, "closed-loop-angle");
+                if (resolveClosedLoop) {
+                  resolveClosedLoop({ mode: "angle", reached: true, achieved_deg: achievedDeg, timeout: false });
+                  resolveClosedLoop = null;
+                }
+              }
+            },
+          );
+          active.odomSub = odomSub;
+          api.logger.info(
+            `ros2_cmd_vel: closed-loop angle enabled topic=${topic} odom_topic=${odomTopic} target_deg=${angleDeg.toFixed(1)} timeout_ms=${timeoutMs}`,
+          );
+        } else if (useClosedLoopDistance) {
+          let lastPos: { x: number; y: number } | null = null;
+          let accumulatedM = 0;
+          const transport = getTransport();
+          const odomSub = transport.subscribe(
+            { topic: odomTopic, type: ODOM_TYPE },
+            (msg: Record<string, unknown>) => {
+              const pos = positionXYFromOdom(msg);
+              if (!pos) return;
+              if (!lastPos) {
+                lastPos = pos;
+                return;
+              }
+              const dx = pos.x - lastPos.x;
+              const dy = pos.y - lastPos.y;
+              lastPos = pos;
+              accumulatedM += Math.hypot(dx, dy);
+              if (accumulatedM >= targetDistanceM) {
+                api.logger.info(
+                  `ros2_cmd_vel: closed-loop distance reached topic=${topic} odom_topic=${odomTopic} target_m=${targetDistanceM.toFixed(3)} achieved_m=${accumulatedM.toFixed(3)} at=${new Date().toISOString()}`,
+                );
+                stopMotion(topic, api.logger, "closed-loop-distance");
+                if (resolveClosedLoop) {
+                  resolveClosedLoop({ mode: "distance", reached: true, achieved_m: accumulatedM, timeout: false });
+                  resolveClosedLoop = null;
+                }
+              }
+            },
+          );
+          active.odomSub = odomSub;
+          api.logger.info(
+            `ros2_cmd_vel: closed-loop distance enabled topic=${topic} odom_topic=${odomTopic} target_m=${targetDistanceM.toFixed(3)} timeout_ms=${timeoutMs}`,
+          );
+        }
+
+        activeMotions.set(topic, active);
+
+        let closedLoopResult: { mode: "angle" | "distance"; reached: boolean; timeout: boolean; achieved_deg?: number; achieved_m?: number } | null = null;
+        if (closedLoopPromise) {
+          closedLoopResult = await closedLoopPromise;
+        }
+
+        const summary =
+          `Published cmd_vel linear.x=${linearX.toFixed(3)} angular.z=${angularZ.toFixed(3)} ` +
+          `to ${topic} for ${durationS.toFixed(2)}s (continuous publish, auto-stop armed).` +
+          (closedLoopResult
+            ? closedLoopResult.reached
+              ? closedLoopResult.mode === "angle"
+                ? ` Closed-loop angle reached (${(closedLoopResult.achieved_deg ?? 0).toFixed(1)} deg).`
+                : ` Closed-loop distance reached (${(closedLoopResult.achieved_m ?? 0).toFixed(3)} m).`
+              : closedLoopResult.mode === "angle"
+                ? ` Closed-loop angle timeout before target.`
+                : ` Closed-loop distance timeout before target.`
+            : "");
+
+        return {
+          content: [{ type: "text", text: summary }],
+          details: {
+            success: true,
+            topic,
+            type: TWIST_TYPE,
+            linear_x: linearX,
+            angular_z: angularZ,
+            duration_s: durationS,
+            direction: direction ?? null,
+            distance_m: distanceM,
+            angle_deg: angleDeg,
+            odom_topic: useClosedLoopOdom ? odomTopic : null,
+            closed_loop_angle: useClosedLoopAngle,
+            closed_loop_distance: useClosedLoopDistance,
+            closed_loop_reached: closedLoopResult?.reached ?? null,
+            closed_loop_timeout: closedLoopResult?.timeout ?? null,
+            achieved_angle_deg: closedLoopResult?.achieved_deg ?? null,
+            achieved_distance_m: closedLoopResult?.achieved_m ?? null,
+            target_distance_m: useClosedLoopDistance ? targetDistanceM : null,
+          },
+        };
+      },
+    },
+    {
+      names: ["ros2_cmd_vel", "cmd_vel", "move_base"],
+    },
+  );
+}
