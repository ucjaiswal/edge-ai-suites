+import { Type } from "@sinclair/typebox";
+import type { OpenClawPluginApi } from "../plugin-api.js";
+import type { AgenticROSConfig } from "@agenticros/core";
+import { toNamespacedTopic } from "@agenticros/core";
+import { getTransport } from "../service.js";
+import { getCmdVelTopic } from "../teleop/routes.js";
+
+const TWIST_TYPE = "geometry_msgs/msg/Twist";
+const ODOM_TYPE = "nav_msgs/msg/Odometry";
+const DEFAULT_LINEAR_SPEED = 0.25;
+const DEFAULT_ANGULAR_SPEED = 0.8;
+const DEFAULT_STEP_DISTANCE_M = 0.4;
+const DEFAULT_STEP_ANGLE_DEG = 45;
+const DEFAULT_FALLBACK_DURATION_S = 1.0;
+const CMD_PUBLISH_INTERVAL_MS = 100;
+const STOP_CONFIRM_DELAY_MS = 120;
+const CLOSED_LOOP_MAX_TIMEOUT_S = 20;
+
+type DirectionIntent =
+  | "forward"
+  | "backward"
+  | "left"
+  | "right"
+  | "rotate_left"
+  | "rotate_right"
+  | "stop";
+
+type ActiveMotion = {
+  intervalId: ReturnType<typeof setInterval>;
+  timeoutId: ReturnType<typeof setTimeout>;
+  odomSub?: { unsubscribe(): void };
+};
+
+const activeMotions = new Map<string, ActiveMotion>();
+
+function clamp(value: number, min: number, max: number): number {
+  return Math.max(min, Math.min(max, value));
+}
+
+function safeNumber(value: unknown, fallback = 0): number {
+  const n = Number(value);
+  return Number.isFinite(n) ? n : fallback;
+}
+
+function publishTwist(topic: string, linearX: number, angularZ: number): void {
+  const transport = getTransport();
+  transport.publish({
+    topic,
+    type: TWIST_TYPE,
+    msg: {
+      linear: { x: linearX, y: 0, z: 0 },
+      angular: { x: 0, y: 0, z: angularZ },
+    },
+  });
+}
+
+function normalizeAngleRad(angle: number): number {
+  let a = angle;
+  while (a > Math.PI) a -= 2 * Math.PI;
+  while (a < -Math.PI) a += 2 * Math.PI;
+  return a;
+}
+
+function yawFromQuaternion(msg: Record<string, unknown>): number | null {
+  const pose = msg["pose"] as Record<string, unknown> | undefined;
+  const posePose = pose?.["pose"] as Record<string, unknown> | undefined;
+  const orientation = posePose?.["orientation"] as Record<string, unknown> | undefined;
+  if (!orientation) return null;
+  const x = Number(orientation["x"] ?? NaN);
+  const y = Number(orientation["y"] ?? NaN);
+  const z = Number(orientation["z"] ?? NaN);
+  const w = Number(orientation["w"] ?? NaN);
+  if (![x, y, z, w].every(Number.isFinite)) return null;
+
+  const sinyCosp = 2 * (w * z + x * y);
+  const cosyCosp = 1 - 2 * (y * y + z * z);
+  return Math.atan2(sinyCosp, cosyCosp);
+}
+
+function positionXYFromOdom(msg: Record<string, unknown>): { x: number; y: number } | null {
+  const pose = msg["pose"] as Record<string, unknown> | undefined;
+  const posePose = pose?.["pose"] as Record<string, unknown> | undefined;
+  const position = posePose?.["position"] as Record<string, unknown> | undefined;
+  if (!position) return null;
+  const x = Number(position["x"] ?? NaN);
+  const y = Number(position["y"] ?? NaN);
+  if (!Number.isFinite(x) || !Number.isFinite(y)) return null;
+  return { x, y };
+}
+
+function stopMotion(topic: string, logger?: OpenClawPluginApi["logger"], reason = "manual"): void {
+  const current = activeMotions.get(topic);
+  if (current) {
+    clearInterval(current.intervalId);
+    clearTimeout(current.timeoutId);
+    try {
+      current.odomSub?.unsubscribe();
+    } catch {
+      // Best effort.
+    }
+    activeMotions.delete(topic);
+  }
+  try {
+    logger?.info(`ros2_cmd_vel: stop publish (reason=${reason}) topic=${topic}`);
+    publishTwist(topic, 0, 0);
+    // Send a second stop shortly after as a safety confirm for lossy links.
+    setTimeout(() => {
+      try {
+        logger?.info(`ros2_cmd_vel: stop confirm publish topic=${topic}`);
+        publishTwist(topic, 0, 0);
+      } catch {
+        // Best effort.
+      }
+    }, STOP_CONFIRM_DELAY_MS);
+  } catch {
+    // Best effort.
+  }
+}
+
+function resolveIntent(direction: DirectionIntent | undefined, maxLinear: number, maxAngular: number): { linearX: number; angularZ: number; defaultDuration: number } {
+  switch (direction) {
+    case "forward": {
+      const v = Math.min(DEFAULT_LINEAR_SPEED, maxLinear);
+      return { linearX: v, angularZ: 0, defaultDuration: DEFAULT_STEP_DISTANCE_M / Math.max(Math.abs(v), 1e-6) };
+    }
+    case "backward": {
+      const v = Math.min(DEFAULT_LINEAR_SPEED, maxLinear);
+      return { linearX: -v, angularZ: 0, defaultDuration: DEFAULT_STEP_DISTANCE_M / Math.max(Math.abs(v), 1e-6) };
+    }
+    case "left":
+    case "rotate_left": {
+      const w = Math.min(DEFAULT_ANGULAR_SPEED, maxAngular);
+      return {
+        linearX: 0,
+        angularZ: w,
+        defaultDuration: (DEFAULT_STEP_ANGLE_DEG * Math.PI) / 180 / Math.max(Math.abs(w), 1e-6),
+      };
+    }
+    case "right":
+    case "rotate_right": {
+      const w = Math.min(DEFAULT_ANGULAR_SPEED, maxAngular);
+      return {
+        linearX: 0,
+        angularZ: -w,
+        defaultDuration: (DEFAULT_STEP_ANGLE_DEG * Math.PI) / 180 / Math.max(Math.abs(w), 1e-6),
+      };
+    }
+    case "stop":
+      return { linearX: 0, angularZ: 0, defaultDuration: 0 };
+    default:
+      return { linearX: 0, angularZ: 0, defaultDuration: DEFAULT_FALLBACK_DURATION_S };
+  }
+}
