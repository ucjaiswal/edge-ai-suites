+        api.logger.warn(`Blocked ros2_cmd_vel: angular velocity ${angularZ} exceeds limit ${safety.maxAngularVelocity}`);
+        return {
+          block: true,
+          blockReason: `Angular velocity ${angularZ.toFixed(2)} rad/s exceeds safety limit of ${safety.maxAngularVelocity} rad/s`,
+        };
