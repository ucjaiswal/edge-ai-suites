+import test from "node:test";
+import assert from "node:assert/strict";
+
+import { parseConfig } from "../../packages/core/src/config.ts";
+import { getLandingPageHtml } from "../../packages/agenticros/src/landing-page.ts";
+import { registerSafetyHook } from "../../packages/agenticros/src/safety/validator.ts";
+import type {
+  BeforeToolCallEvent,
+  BeforeToolCallHandler,
+  OpenClawPluginApi,
+} from "../../packages/agenticros/src/plugin-api.ts";
+
+function createSafetyHarness(overrides?: Record<string, unknown>) {
+  const warnings: string[] = [];
+  let beforeToolCallHandler: BeforeToolCallHandler | undefined;
+
+  const api = {
+    logger: {
+      info() {},
+      warn(message: string) {
+        warnings.push(message);
+      },
+      error() {},
+    },
+    registerTool() {},
+    registerService() {},
+    registerCommand() {},
+    on(hookName: "before_agent_start" | "before_tool_call", handler: unknown) {
+      if (hookName === "before_tool_call") {
+        beforeToolCallHandler = handler as BeforeToolCallHandler;
+      }
+    },
+  } as unknown as OpenClawPluginApi;
+
+  const config = parseConfig({
+    safety: {
+      maxLinearVelocity: 0.5,
+      maxAngularVelocity: 0.75,
+    },
+    ...overrides,
+  });
+
+  registerSafetyHook(api, config);
+  assert(beforeToolCallHandler, "before_tool_call hook should be registered");
+
+  return {
+    warnings,
+    async invoke(event: BeforeToolCallEvent) {
+      return beforeToolCallHandler!(event, { toolName: event.toolName });
+    },
+  };
+}
+
+test("registerSafetyHook blocks ros2_publish when linear speed exceeds the configured limit", async () => {
+  const harness = createSafetyHarness();
+
+  const result = await harness.invoke({
+    toolName: "ros2_publish",
+    params: {
+      message: {
+        linear: { x: 0.4, y: 0.4, z: 0 },
+        angular: { z: 0.1 },
+      },
+    },
+  });
+
+  assert.equal(result?.block, true);
+  assert.match(result?.blockReason ?? "", /Linear velocity/);
+  assert.equal(harness.warnings.length, 1);
+});
+
+test("registerSafetyHook blocks ros2_cmd_vel when angular speed exceeds the configured limit", async () => {
+  const harness = createSafetyHarness();
+
+  const result = await harness.invoke({
+    toolName: "ros2_cmd_vel",
+    params: {
+      linear_x: 0.1,
+      angular_z: -1.2,
+    },
+  });
+
+  assert.equal(result?.block, true);
+  assert.match(result?.blockReason ?? "", /Angular velocity/);
+  assert.equal(harness.warnings.length, 1);
+});
+
+test("registerSafetyHook allows safe ros2_cmd_vel inputs", async () => {
+  const harness = createSafetyHarness();
+
+  const result = await harness.invoke({
+    toolName: "ros2_cmd_vel",
+    params: {
+      linear_x: 0.2,
+      angular_z: 0.3,
+    },
+  });
+
+  assert.equal(result, undefined);
+  assert.equal(harness.warnings.length, 0);
+});
+
+test("getLandingPageHtml returns the expected navigation links", () => {
+  const html = getLandingPageHtml();
+
+  assert.match(html, /<h1>AgenticROS<\/h1>/);
+  assert.match(html, /href="config"/);
+  assert.match(html, /href="teleop\/"/);
+  assert.match(html, /natural language control of robots/i);
+});
