+++ b/scripts/unit-test-json-reporter.mjs
@@ -0,0 +1,133 @@
+import { Transform } from 'node:stream';
+
+function toSerializable(value, seen = new WeakSet()) {
+  if (value == null) {
+    return value;
+  }
+
+  if (typeof value === 'bigint') {
+    return value.toString();
+  }
+
+  if (typeof value === 'function') {
+    return `[Function ${value.name || 'anonymous'}]`;
+  }
+
+  if (typeof value === 'symbol') {
+    return value.toString();
+  }
+
+  if (typeof value !== 'object') {
+    return value;
+  }
+
+  if (seen.has(value)) {
+    return '[Circular]';
+  }
+
+  seen.add(value);
+
+  try {
+    if (value instanceof Error) {
+      return {
+        name: value.name,
+        message: value.message,
+        stack: value.stack,
+        cause: toSerializable(value.cause, seen),
+      };
+    }
+
+    if (Buffer.isBuffer(value)) {
+      return {
+        type: 'Buffer',
+        data: Array.from(value.values()),
+      };
+    }
+
+    if (ArrayBuffer.isView(value)) {
+      return {
+        type: value.constructor.name,
+        data: Array.from(value),
+      };
+    }
+
+    if (value instanceof ArrayBuffer) {
+      return {
+        type: 'ArrayBuffer',
+        byteLength: value.byteLength,
+      };
+    }
+
+    if (Array.isArray(value)) {
+      return value.map((item) => toSerializable(item, seen));
+    }
+
+    if (value instanceof Map) {
+      return Array.from(value.entries()).map(([key, mapValue]) => ({
+        key: toSerializable(key, seen),
+        value: toSerializable(mapValue, seen),
+      }));
+    }
+
+    if (value instanceof Set) {
+      return Array.from(value.values()).map((item) => toSerializable(item, seen));
+    }
+
+    const result = {};
+
+    for (const key of Reflect.ownKeys(value)) {
+      const normalizedKey = typeof key === 'symbol' ? key.toString() : key;
+
+      try {
+        result[normalizedKey] = toSerializable(value[key], seen);
+      } catch (error) {
+        result[normalizedKey] = {
+          serializationError: error instanceof Error ? error.message : String(error),
+        };
+      }
+    }
+
+    return result;
+  } finally {
+    seen.delete(value);
+  }
+}
+
+class UnitTestJsonReporter extends Transform {
+  constructor() {
+    super({ writableObjectMode: true });
+    this.eventCounts = {};
+    this.events = [];
+    this.startedAt = new Date().toISOString();
+  }
+
+  _transform(event, _encoding, callback) {
+    try {
+      const eventType = typeof event?.type === 'string' ? event.type : 'unknown';
+      this.eventCounts[eventType] = (this.eventCounts[eventType] ?? 0) + 1;
+      this.events.push(toSerializable(event));
+      callback();
+    } catch (error) {
+      callback(error);
+    }
+  }
+
+  _flush(callback) {
+    try {
+      const report = {
+        reporter: 'unit-test-json-reporter',
+        startedAt: this.startedAt,
+        generatedAt: new Date().toISOString(),
+        eventCounts: this.eventCounts,
+        events: this.events,
+      };
+      callback(null, `${JSON.stringify(report, null, 2)}\n`);
+    } catch (error) {
+      callback(error);
+    }
+  }
+}
+
+export default function unitTestJsonReporter() {
+  return new UnitTestJsonReporter();
+}
