diff --git a/scripts/fuzz_ros_payloads.mjs b/scripts/fuzz_ros_payloads.mjs
new file mode 100755
index 0000000..92b794e
--- /dev/null
+++ b/scripts/fuzz_ros_payloads.mjs
@@ -0,0 +1,585 @@
+#!/usr/bin/env node
+
+import assert from "node:assert/strict";
+import fs from "node:fs";
+import os from "node:os";
+import path from "node:path";
+import process from "node:process";
+import { fileURLToPath, pathToFileURL } from "node:url";
+
+const __filename = fileURLToPath(import.meta.url);
+const __dirname = path.dirname(__filename);
+const repoRoot = path.resolve(__dirname, "..");
+
+const options = parseArgs(process.argv.slice(2));
+fs.mkdirSync(options.reportDir, { recursive: true });
+
+const rosCameraModule = await importDistModule("packages/ros-camera/dist/index.js");
+const coreConversionModule = await importDistModule("packages/core/dist/transport/local/conversion.js");
+const agenticrosDepthModule = await importSourceModule("packages/agenticros/src/depth.ts");
+const agenticrosConfigFileModule = await importSourceModule("packages/agenticros/src/config-file.ts");
+
+const {
+  cameraSnapshotFromPlainMessage,
+  coerceRosImageDataToBuffer,
+  mimeTypeForSnapshotBase64,
+  rosNumericField,
+} = rosCameraModule;
+const { fromRosMessage } = coreConversionModule;
+const { getDepthDistance, getDepthSectors, sampleDepthMeters } = agenticrosDepthModule;
+const {
+  ConfigFileError,
+  getOpenClawConfigPath,
+  readOpenClawConfig,
+  readAgenticROSConfigFromFile,
+  writeAgenticROSConfig,
+} = agenticrosConfigFileModule;
+
+const prng = createPrng(options.seed);
+const startedAt = new Date().toISOString();
+const startedMs = Date.now();
+
+const targets = [
+  {
+    name: "coerceRosImageDataToBuffer",
+    run() {
+      const bytes = randomBytes(prng, 1 + prng.int(255));
+      const shaped = makeByteSourceCase(prng, bytes);
+      let result;
+      try {
+        result = coerceRosImageDataToBuffer(shaped.value);
+      } catch (error) {
+        const message = error instanceof Error ? error.message : String(error);
+        throw new Error(`byte source ${shaped.kind} failed: ${message}`);
+      }
+      assert(Buffer.isBuffer(result), "expected a Buffer result");
+      assert(result.equals(Buffer.from(bytes)), "buffer content mismatch after coercion");
+    },
+  },
+  {
+    name: "cameraSnapshotFromPlainMessage:CompressedImage",
+    run() {
+      const bytes = randomBytes(prng, 1 + prng.int(256));
+      const shaped = makeByteSourceCase(prng, bytes);
+      const msg = {
+        format: randomCompressedFormat(prng),
+        data: shaped.value,
+      };
+      const payload = cameraSnapshotFromPlainMessage("CompressedImage", msg);
+      assert.equal(typeof payload.formatLabel, "string", "formatLabel should be a string");
+      assert(payload.formatLabel.length > 0, "formatLabel should not be empty");
+      assert.equal(payload.dataBase64, Buffer.from(bytes).toString("base64"), "compressed snapshot base64 mismatch");
+      assert(mimeTypeForSnapshotBase64(payload.dataBase64, payload.formatLabel).startsWith("image/"), "mime type should be image/*");
+    },
+  },
+  {
+    name: "cameraSnapshotFromPlainMessage:Image",
+    run() {
+      const image = makeRawImageMessage(prng);
+      const payload = cameraSnapshotFromPlainMessage("Image", image.message);
+      assert.equal(payload.formatLabel, "png", "raw image snapshots should be PNG");
+      assert.equal(payload.width, image.width, "width mismatch");
+      assert.equal(payload.height, image.height, "height mismatch");
+      assert(mimeTypeForSnapshotBase64(payload.dataBase64, payload.formatLabel) === "image/png", "raw image should encode as PNG");
+      const encoded = Buffer.from(payload.dataBase64, "base64");
+      assert(encoded.length >= 8, "PNG output too small");
+      assert.equal(encoded.subarray(0, 8).toString("hex"), "89504e470d0a1a0a", "PNG magic mismatch");
+    },
+  },
+  {
+    name: "fromRosMessage:Image",
+    run() {
+      const image = makeRawImageMessage(prng);
+      const plain = fromRosMessage(image.message, "sensor_msgs/msg/Image");
+      assert.equal(typeof plain, "object", "expected plain object from Image conversion");
+      const data = coerceRosImageDataToBuffer(plain.data);
+      assert(data.equals(Buffer.from(image.bytes)), "Image data changed during extraction");
+      assert.equal(rosNumericField(plain.width, "width"), image.width, "plain Image width mismatch");
+      assert.equal(rosNumericField(plain.height, "height"), image.height, "plain Image height mismatch");
+    },
+  },
+  {
+    name: "fromRosMessage:CompressedImage",
+    run() {
+      const bytes = randomBytes(prng, 1 + prng.int(256));
+      const shaped = makeByteSourceCase(prng, bytes);
+      const message = {
+        header: randomHeader(prng),
+        format: randomCompressedFormat(prng),
+        data: shaped.value,
+      };
+      const plain = fromRosMessage(message, "sensor_msgs/msg/CompressedImage");
+      assert.equal(typeof plain, "object", "expected plain object from CompressedImage conversion");
+      const data = coerceRosImageDataToBuffer(plain.data);
+      assert(data.equals(Buffer.from(bytes)), "CompressedImage data changed during extraction");
+      assert.equal(typeof plain.format, "string", "plain CompressedImage format should be string");
+    },
+  },
+  {
+    name: "sampleDepthMeters:valid",
+    run() {
+      const depthCase = makeDepthImageCase(prng, { forcePositive: false });
+      const values = sampleDepthMeters(
+        depthCase.width,
+        depthCase.height,
+        depthCase.step,
+        depthCase.encoding,
+        depthCase.data,
+        randomCenterFraction(prng),
+        depthCase.isBigEndian,
+      );
+      for (const value of values) {
+        assert(Number.isFinite(value), "depth sample should be finite");
+        assert(value > 0, "depth sample should be positive");
+      }
+    },
+  },
+  {
+    name: "sampleDepthMeters:invalidEncoding",
+    run() {
+      const depthCase = makeDepthImageCase(prng, { forcePositive: false });
+      assert.throws(
+        () => sampleDepthMeters(depthCase.width, depthCase.height, depthCase.step, `bad-${randomAscii(prng, 3, 8)}`, depthCase.data),
+        /Unsupported depth encoding/,
+      );
+    },
+  },
+  {
+    name: "getDepthDistance:syncTransport",
+    async run() {
+      const depthCase = makeDepthImageCase(prng, { forcePositive: true });
+      const message = depthCase.message;
+      const result = await getDepthDistance(makeMockTransport(message, { sync: true }), "/depth");
+      assert.equal(result.topic, "/depth", "depth distance topic mismatch");
+      assert.equal(result.valid, true, "depth distance should be valid");
+      assert(Number.isFinite(result.distance_m) && result.distance_m > 0, "depth distance should be positive");
+      assert(result.sample_count > 0, "depth distance should contain samples");
+    },
+  },
+  {
+    name: "getDepthSectors:syncTransport",
+    async run() {
+      const depthCase = makeDepthImageCase(prng, { forcePositive: true });
+      const result = await getDepthSectors(makeMockTransport(depthCase.message, { sync: true }), "/depth");
+      assert.equal(result.topic, "/depth", "depth sectors topic mismatch");
+      assert.equal(result.valid, true, "depth sectors should be valid");
+      assert(Number.isFinite(result.left_m) && result.left_m > 0, "left sector should be positive");
+      assert(Number.isFinite(result.center_m) && result.center_m > 0, "center sector should be positive");
+      assert(Number.isFinite(result.right_m) && result.right_m > 0, "right sector should be positive");
+    },
+  },
+  {
+    name: "configFile:invalidJson",
+    run() {
+      withOpenClawConfigFile("{invalid-json", () => {
+        assert.throws(
+          () => readOpenClawConfig(),
+          (error) => error instanceof ConfigFileError && error.code === "INVALID_JSON",
+        );
+      });
+    },
+  },
+  {
+    name: "configFile:writeReadRoundTrip",
+    run() {
+      withOpenClawConfigFile("{}", () => {
+        const pathFromEnv = getOpenClawConfigPath();
+        assert(path.isAbsolute(pathFromEnv), "resolved OpenClaw config path should be absolute");
+        writeAgenticROSConfig({});
+        const raw = readOpenClawConfig();
+        assert.equal(typeof raw, "object", "raw config should be an object");
+        const parsed = readAgenticROSConfigFromFile();
+        assert.equal(typeof parsed, "object", "parsed plugin config should be an object");
+        assert.equal(typeof parsed.safety.maxLinearVelocity, "number", "parsed config should include safety defaults");
+        assert(parsed.safety.maxLinearVelocity > 0, "parsed config should include positive linear velocity limit");
+      });
+    },
+  },
+];
+
+const summary = {
+  seed: options.seed,
+  iterationsPerTarget: options.iterations,
+  startedAt,
+  finishedAt: "",
+  durationMs: 0,
+  targets: {},
+  failureCount: 0,
+};
+
+let firstFailure = null;
+
+for (const target of targets) {
+  const stats = { runs: 0, failures: 0 };
+  for (let i = 0; i < options.iterations; i++) {
+    stats.runs += 1;
+    try {
+      await target.run();
+    } catch (error) {
+      stats.failures += 1;
+      summary.failureCount += 1;
+      if (firstFailure === null) {
+        firstFailure = {
+          target: target.name,
+          iteration: i,
+          error: error instanceof Error ? { name: error.name, message: error.message, stack: error.stack } : { name: "UnknownError", message: String(error) },
+        };
+      }
+      break;
+    }
+  }
+  summary.targets[target.name] = stats;
+}
+
+summary.finishedAt = new Date().toISOString();
+summary.durationMs = Date.now() - startedMs;
+if (firstFailure !== null) {
+  summary.firstFailure = firstFailure;
+}
+
+const textSummary = buildTextSummary(summary, firstFailure);
+fs.writeFileSync(path.join(options.reportDir, "summary.json"), `${JSON.stringify(summary, null, 2)}\n`, "utf8");
+fs.writeFileSync(path.join(options.reportDir, "summary.txt"), textSummary, "utf8");
+
+console.log(textSummary.trimEnd());
+
+if (summary.failureCount > 0) {
+  process.exitCode = 1;
+}
+
+function parseArgs(argv) {
+  const out = {
+    iterations: 1000,
+    seed: (Date.now() >>> 0) || 0x1a2b3c4d,
+    reportDir: path.resolve(repoRoot, "build/fuzz/report"),
+  };
+
+  for (let i = 0; i < argv.length; i++) {
+    const arg = argv[i];
+    if (arg === "--iterations") {
+      const value = Number(argv[++i]);
+      if (!Number.isInteger(value) || value <= 0) throw new Error("--iterations must be a positive integer");
+      out.iterations = value;
+      continue;
+    }
+    if (arg === "--seed") {
+      const value = Number(argv[++i]);
+      if (!Number.isInteger(value)) throw new Error("--seed must be an integer");
+      out.seed = value >>> 0;
+      continue;
+    }
+    if (arg === "--report-dir") {
+      const value = argv[++i];
+      if (!value) throw new Error("--report-dir requires a path");
+      out.reportDir = path.resolve(process.cwd(), value);
+      continue;
+    }
+    throw new Error(`Unknown argument: ${arg}`);
+  }
+
+  return out;
+}
+
+async function importDistModule(relativePath) {
+  const absPath = path.resolve(repoRoot, relativePath);
+  if (!fs.existsSync(absPath)) {
+    throw new Error(`Required build artifact not found: ${absPath}`);
+  }
+  return import(pathToFileURL(absPath).href);
+}
+
+async function importSourceModule(relativePath) {
+  const absPath = path.resolve(repoRoot, relativePath);
+  if (!fs.existsSync(absPath)) {
+    throw new Error(`Required source file not found: ${absPath}`);
+  }
+  return import(pathToFileURL(absPath).href);
+}
+
+function createPrng(seed) {
+  let state = seed >>> 0;
+  if (state === 0) state = 0x6d2b79f5;
+  return {
+    nextUint32() {
+      state ^= state << 13;
+      state ^= state >>> 17;
+      state ^= state << 5;
+      return state >>> 0;
+    },
+    int(maxExclusive) {
+      return this.nextUint32() % maxExclusive;
+    },
+    bool() {
+      return (this.nextUint32() & 1) === 1;
+    },
+    pick(values) {
+      return values[this.int(values.length)];
+    },
+  };
+}
+
+function randomBytes(random, length) {
+  const size = Math.max(0, length);
+  const bytes = new Uint8Array(size);
+  for (let i = 0; i < size; i++) {
+    bytes[i] = random.int(256);
+  }
+  return bytes;
+}
+
+function randomAscii(random, minLength = 0, maxLength = 24) {
+  const alphabet = "abcdefghijklmnopqrstuvwxyz0123456789_-";
+  const length = minLength + random.int(maxLength - minLength + 1);
+  let result = "";
+  for (let i = 0; i < length; i++) {
+    result += alphabet[random.int(alphabet.length)];
+  }
+  return result;
+}
+
+function wrapNumeric(random, value, depth = 0) {
+  const normalized = Math.max(0, Math.trunc(value));
+  const variants = [
+    () => normalized,
+    () => BigInt(normalized),
+    () => String(normalized),
+  ];
+
+  if (depth < 2) {
+    variants.push(() => ({ data: wrapNumeric(random, normalized, depth + 1) }));
+  }
+
+  return random.pick(variants)();
+}
+
+function makeByteSourceCase(random, bytes, depth = 0) {
+  const asArray = Array.from(bytes);
+  const variants = [
+    () => ({ kind: "buffer", value: Buffer.from(bytes) }),
+    () => ({ kind: "uint8array", value: Uint8Array.from(bytes) }),
+    () => ({ kind: "arraybuffer", value: bytes.buffer.slice(bytes.byteOffset, bytes.byteOffset + bytes.byteLength) }),
+    () => ({ kind: "array", value: asArray.slice() }),
+    () => ({ kind: "json-buffer", value: { type: "Buffer", data: asArray.slice() } }),
+    () => {
+      const record = {};
+      for (let i = 0; i < asArray.length; i++) record[i] = asArray[i];
+      return { kind: "dense-record", value: record };
+    },
+    () => {
+      const arrayLike = { length: asArray.length };
+      for (let i = 0; i < asArray.length; i++) arrayLike[i] = asArray[i];
+      return { kind: "array-like", value: arrayLike };
+    },
+    () => ({
+      kind: "iterable",
+      value: {
+        [Symbol.iterator]: function* iterator() {
+          yield* asArray;
+        },
+      },
+    }),
+  ];
+
+  if (depth < 2) {
+    variants.push(() => {
+      const nested = makeByteSourceCase(random, bytes, depth + 1);
+      return { kind: `data-wrapper<${nested.kind}>`, value: { data: nested.value } };
+    });
+  }
+
+  return random.pick(variants)();
+}
+
+function randomCompressedFormat(random) {
+  return random.pick([
+    "jpeg",
+    "jpg",
+    "png",
+    "webp",
+    "jpeg; compressed",
+    "png compressed",
+    "rgb8; jpeg compressed",
+    "",
+  ]);
+}
+
+function randomCenterFraction(random) {
+  return 0.1 + (random.int(50) / 100);
+}
+
+function bytesPerPixel(encoding) {
+  switch (encoding.toLowerCase()) {
+    case "rgb8":
+    case "bgr8":
+      return 3;
+    case "rgba8":
+    case "bgra8":
+      return 4;
+    case "mono8":
+    case "8uc1":
+      return 1;
+    default:
+      throw new Error(`Unsupported fuzz encoding: ${encoding}`);
+  }
+}
+
+function makeRawImageMessage(random) {
+  const encoding = random.pick(["rgb8", "bgr8", "rgba8", "bgra8", "mono8", "8UC1"]);
+  const width = 1 + random.int(24);
+  const height = 1 + random.int(24);
+  const bpp = bytesPerPixel(encoding);
+  const rowPadding = random.int(3);
+  const step = width * bpp + rowPadding;
+  const bytes = randomBytes(random, step * height);
+  const message = {
+    header: randomHeader(random),
+    encoding,
+    width: wrapNumeric(random, width),
+    height: wrapNumeric(random, height),
+    is_bigendian: random.pick([0, 1, false, true, { data: 0 }, { data: 1 }]),
+    step: wrapNumeric(random, step),
+    data: makeByteSourceCase(random, bytes).value,
+  };
+  return { message, width, height, bytes };
+}
+
+function makeDepthImageCase(random, options = {}) {
+  const encoding = random.pick(["16UC1", "mono16", "32FC1"]);
+  const width = 3 + random.int(22);
+  const height = 3 + random.int(22);
+  const isBigEndian = random.bool();
+  const bpp = encoding.toLowerCase() === "32fc1" ? 4 : 2;
+  const paddingUnits = random.int(3);
+  const step = width * bpp + paddingUnits * bpp;
+  const data = new Uint8Array(step * height);
+  fillDepthBytes(data, width, height, step, encoding, isBigEndian, random, options.forcePositive === true);
+
+  return {
+    encoding,
+    width,
+    height,
+    step,
+    isBigEndian,
+    data,
+    message: {
+      encoding,
+      width: wrapNumeric(random, width),
+      height: wrapNumeric(random, height),
+      step: wrapNumeric(random, step),
+      is_bigendian: random.pick([isBigEndian, Number(isBigEndian), { data: Number(isBigEndian) }]),
+      data: makeByteSourceCase(random, data).value,
+    },
+  };
+}
+
+function fillDepthBytes(buffer, width, height, step, encoding, isBigEndian, random, forcePositive) {
+  if (encoding.toLowerCase() === "32fc1") {
+    for (let y = 0; y < height; y++) {
+      for (let x = 0; x < width; x++) {
+        const off = y * step + x * 4;
+        const value = forcePositive
+          ? 0.2 + (random.int(4800) / 1000)
+          : random.bool()
+            ? 0
+            : (random.int(10000) - 2000) / 1000;
+        new DataView(buffer.buffer, buffer.byteOffset + off, 4).setFloat32(0, value, !isBigEndian);
+      }
+    }
+    return;
+  }
+
+  for (let y = 0; y < height; y++) {
+    for (let x = 0; x < width; x++) {
+      const off = y * step + x * 2;
+      const value = forcePositive ? 200 + random.int(5000) : random.bool() ? 0 : 1 + random.int(6000);
+      if (isBigEndian) {
+        buffer[off] = (value >> 8) & 0xff;
+        buffer[off + 1] = value & 0xff;
+      } else {
+        buffer[off] = value & 0xff;
+        buffer[off + 1] = (value >> 8) & 0xff;
+      }
+    }
+  }
+}
+
+function makeMockTransport(message, options = {}) {
+  return {
+    connect: async () => {},
+    disconnect: async () => {},
+    getStatus: () => "connected",
+    onConnection: () => () => {},
+    publish: async () => {},
+    subscribe: (_subscribeOptions, handler) => {
+      const subscription = { unsubscribe() {} };
+      const deliver = () => handler(message);
+      if (options.sync === true) {
+        deliver();
+      } else {
+        queueMicrotask(deliver);
+      }
+      return subscription;
+    },
+    callService: async () => ({ result: false }),
+    sendActionGoal: async () => ({ result: false }),
+    cancelActionGoal: async () => {},
+    listTopics: async () => [],
+    listServices: async () => [],
+    listActions: async () => [],
+  };
+}
+
+function withOpenClawConfigFile(contents, fn) {
+  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), "agenticros-fuzz-config-"));
+  const configPath = path.join(tempDir, "openclaw.json");
+  fs.writeFileSync(configPath, contents, "utf8");
+  const previous = process.env.OPENCLAW_CONFIG;
+  process.env.OPENCLAW_CONFIG = configPath;
+  try {
+    return fn(configPath);
+  } finally {
+    if (previous === undefined) {
+      delete process.env.OPENCLAW_CONFIG;
+    } else {
+      process.env.OPENCLAW_CONFIG = previous;
+    }
+    fs.rmSync(tempDir, { recursive: true, force: true });
+  }
+}
+
+function randomHeader(random) {
+  return {
+    frame_id: randomAscii(random, 3, 12),
+    stamp: {
+      sec: random.pick([random.int(10_000), BigInt(random.int(10_000))]),
+      nanosec: random.pick([random.int(1_000_000_000), BigInt(random.int(1_000_000_000))]),
+    },
+  };
+}
+
+function buildTextSummary(summary, firstFailure) {
+  const lines = [];
+  lines.push(`Fuzz run started: ${summary.startedAt}`);
+  lines.push(`Fuzz run finished: ${summary.finishedAt}`);
+  lines.push(`Seed: ${summary.seed}`);
+  lines.push(`Iterations per target: ${summary.iterationsPerTarget}`);
+  lines.push("");
+  lines.push("Targets:");
+  for (const [name, stats] of Object.entries(summary.targets)) {
+    lines.push(`- ${name}: runs=${stats.runs}, failures=${stats.failures}`);
+  }
+  lines.push("");
+  lines.push(`Overall failures: ${summary.failureCount}`);
+  lines.push(`Duration: ${summary.durationMs} ms`);
+  if (firstFailure) {
+    lines.push("");
+    lines.push(`First failure target: ${firstFailure.target}`);
+    lines.push(`First failure iteration: ${firstFailure.iteration}`);
+    lines.push(`First failure error: ${firstFailure.error.name}: ${firstFailure.error.message}`);
+  } else {
+    lines.push("");
+    lines.push("No failures detected.");
+  }
+  lines.push("");
+  return `${lines.join("\n")}\n`;
+}
\ No newline at end of file
