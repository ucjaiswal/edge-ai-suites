+import test from "node:test";
+import assert from "node:assert/strict";
+
+import type { RosTransport, Subscription } from "@agenticros/core";
+import {
+  getDepthDistance,
+  getDepthSectors,
+  sampleDepthMeters,
+} from "../../packages/agenticros/src/depth.ts";
+
+function createSyncTransport(message: Record<string, unknown>): RosTransport {
+  return {
+    async connect() {},
+    async disconnect() {},
+    getStatus() { return "connected"; },
+    onConnection() { return () => {}; },
+    async publish() {},
+    subscribe(_options, handler): Subscription {
+      const subscription: Subscription = { unsubscribe() {} };
+      handler(message);
+      return subscription;
+    },
+    async callService() { return { result: false }; },
+    async sendActionGoal() { return { result: false }; },
+    async cancelActionGoal() {},
+    async listTopics() { return []; },
+    async listServices() { return []; },
+    async listActions() { return []; },
+  };
+}
+
+function makeDepthImageMessage16UC1(valueMm: number): Record<string, unknown> {
+  const width = 6;
+  const height = 6;
+  const step = width * 2;
+  const data = new Uint8Array(step * height);
+
+  for (let y = 0; y < height; y++) {
+    for (let x = 0; x < width; x++) {
+      const off = y * step + x * 2;
+      data[off] = valueMm & 0xff;
+      data[off + 1] = (valueMm >> 8) & 0xff;
+    }
+  }
+
+  return {
+    encoding: "16UC1",
+    width,
+    height,
+    step,
+    is_bigendian: false,
+    data,
+  };
+}
+
+test("sampleDepthMeters rejects unsupported depth encodings", () => {
+  assert.throws(
+    () => sampleDepthMeters(2, 2, 4, "bad-encoding", new Uint8Array(16)),
+    /Unsupported depth encoding/,
+  );
+});
+
+test("getDepthDistance handles synchronous transport delivery", async () => {
+  const result = await getDepthDistance(createSyncTransport(makeDepthImageMessage16UC1(1500)), "/depth");
+
+  assert.equal(result.topic, "/depth");
+  assert.equal(result.valid, true);
+  assert.equal(result.distance_m, 1.5);
+  assert.equal(result.sample_count > 0, true);
+});
+
+test("getDepthSectors handles synchronous transport delivery", async () => {
+  const result = await getDepthSectors(createSyncTransport(makeDepthImageMessage16UC1(800)), "/depth");
+
+  assert.equal(result.topic, "/depth");
+  assert.equal(result.valid, true);
+  assert.equal(result.left_m, 0.8);
+  assert.equal(result.center_m, 0.8);
+  assert.equal(result.right_m, 0.8);
+});
