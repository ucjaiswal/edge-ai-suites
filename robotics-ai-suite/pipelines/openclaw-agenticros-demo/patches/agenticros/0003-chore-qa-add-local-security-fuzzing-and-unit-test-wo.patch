+import test from "node:test";
+import assert from "node:assert/strict";
+import fs from "node:fs";
+import os from "node:os";
+import path from "node:path";
+
+import {
+  ConfigFileError,
+  getOpenClawConfigPath,
+  readAgenticROSConfigFromFile,
+  readOpenClawConfig,
+  writeAgenticROSConfig,
+} from "../../packages/agenticros/src/config-file.ts";
+
+function withTempConfig(contents: string, fn: () => void | Promise<void>): Promise<void> | void {
+  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), "agenticros-unit-config-"));
+  const configPath = path.join(tempDir, "openclaw.json");
+  fs.writeFileSync(configPath, contents, "utf8");
+
+  const previous = process.env.OPENCLAW_CONFIG;
+  process.env.OPENCLAW_CONFIG = configPath;
+
+  const cleanup = () => {
+    if (previous === undefined) {
+      delete process.env.OPENCLAW_CONFIG;
+    } else {
+      process.env.OPENCLAW_CONFIG = previous;
+    }
+    fs.rmSync(tempDir, { recursive: true, force: true });
+  };
+
+  try {
+    const result = fn();
+    if (result && typeof (result as Promise<void>).then === "function") {
+      return (result as Promise<void>).finally(cleanup);
+    }
+    cleanup();
+  } catch (error) {
+    cleanup();
+    throw error;
+  }
+}
+
+test("readOpenClawConfig reports invalid JSON", () => {
+  withTempConfig("{invalid-json", () => {
+    assert.throws(
+      () => readOpenClawConfig(),
+      (error) => error instanceof ConfigFileError && error.code === "INVALID_JSON",
+    );
+  });
+});
+
+test("writeAgenticROSConfig and readAgenticROSConfigFromFile round-trip through OPENCLAW_CONFIG", () => {
+  withTempConfig("{}", () => {
+    const resolvedPath = getOpenClawConfigPath();
+    assert.equal(path.isAbsolute(resolvedPath), true);
+
+    writeAgenticROSConfig({
+      robot: { namespace: "robot-123" },
+      safety: { maxLinearVelocity: 0.5, maxAngularVelocity: 0.75 },
+    });
+
+    const raw = readOpenClawConfig();
+    const plugins = raw.plugins as Record<string, unknown>;
+    const entries = plugins.entries as Record<string, unknown>;
+    const agenticros = entries.agenticros as Record<string, unknown>;
+    const config = agenticros.config as Record<string, unknown>;
+    const robot = config.robot as Record<string, unknown>;
+    assert.equal(robot.namespace, "robot-123");
+
+    const parsed = readAgenticROSConfigFromFile();
+    assert.equal(parsed.robot.namespace, "robot-123");
+    assert.equal(parsed.safety.maxLinearVelocity, 0.5);
+    assert.equal(parsed.safety.maxAngularVelocity, 0.75);
+  });
+});
