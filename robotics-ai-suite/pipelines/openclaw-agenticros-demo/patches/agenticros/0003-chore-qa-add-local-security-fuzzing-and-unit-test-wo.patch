+#!/bin/bash
+
+set -euo pipefail
+
+SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
+REPO_ROOT=$(cd "$SCRIPT_DIR/.." && pwd)
+
+FUZZ_ROOT="${FUZZ_ROOT:-$REPO_ROOT/build/fuzz}"
+REPORT_DIR=""
+ITERATIONS=1000
+SEED=""
+CLEAN=1
+BUILD=1
+
+log_info() {
+    printf '[fuzz] %s\n' "$1"
+}
+
+log_error() {
+    printf '[fuzz] ERROR: %s\n' "$1" >&2
+}
+
+die() {
+    log_error "$1"
+    exit 1
+}
+
+require_tool() {
+    command -v "$1" >/dev/null 2>&1 || die "Required tool '$1' was not found in PATH."
+}
+
+show_help() {
+    cat << EOF
+Run local fuzz testing for AgenticROS.
+
+USAGE:
+    $0 [options]
+
+OPTIONS:
+    --iterations N    Iterations per fuzz target (default: 1000)
+    --seed N          Deterministic seed (default: current time)
+    --report-dir PATH Report directory (default: build/fuzz/report)
+    --no-clean        Reuse existing report output
+    --skip-build      Reuse existing package build artifacts
+    -h, --help        Show this help message
+EOF
+}
+
+parse_args() {
+    while [[ $# -gt 0 ]]; do
+        case "$1" in
+            --iterations)
+                [[ $# -ge 2 ]] || die "Missing value for --iterations"
+                ITERATIONS="$2"
+                shift 2
+                ;;
+            --seed)
+                [[ $# -ge 2 ]] || die "Missing value for --seed"
+                SEED="$2"
+                shift 2
+                ;;
+            --report-dir)
+                [[ $# -ge 2 ]] || die "Missing value for --report-dir"
+                REPORT_DIR="$2"
+                shift 2
+                ;;
+            --no-clean)
+                CLEAN=0
+                shift
+                ;;
+            --skip-build)
+                BUILD=0
+                shift
+                ;;
+            -h|--help)
+                show_help
+                exit 0
+                ;;
+            *)
+                die "Unknown argument: $1"
+                ;;
+        esac
+    done
+}
+
+main() {
+    parse_args "$@"
+
+    require_tool node
+    require_tool npx
+    require_tool pnpm
+
+    REPORT_DIR="${REPORT_DIR:-$FUZZ_ROOT/report}"
+
+    if [[ $CLEAN -eq 1 ]]; then
+        rm -rf "$REPORT_DIR"
+    fi
+    mkdir -p "$REPORT_DIR"
+
+    if [[ $BUILD -eq 1 ]]; then
+        log_info "Building @agenticros/core"
+        pnpm --filter @agenticros/core build
+
+        log_info "Building @agenticros/ros-camera"
+        pnpm --filter @agenticros/ros-camera build
+    fi
+
+    local -a fuzz_args=(
+        ./scripts/fuzz_ros_payloads.mjs
+        --iterations "$ITERATIONS"
+        --report-dir "$REPORT_DIR"
+    )
+    if [[ -n "$SEED" ]]; then
+        fuzz_args+=(--seed "$SEED")
+    fi
+
+    log_info "Running fuzz harness"
+    npx --yes tsx "${fuzz_args[@]}"
+
+    log_info "Fuzz testing complete"
+    log_info "Text report: $REPORT_DIR/summary.txt"
+    log_info "JSON report: $REPORT_DIR/summary.json"
+}
+
+main "$@"
