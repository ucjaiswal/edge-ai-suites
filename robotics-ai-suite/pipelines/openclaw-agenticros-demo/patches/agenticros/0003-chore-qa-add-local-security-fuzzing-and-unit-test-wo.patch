new file mode 100755
index 0000000..81e22cc
--- /dev/null
+++ b/scripts/run_bandit_local.sh
@@ -0,0 +1,185 @@
+#!/bin/bash
+
+set -euo pipefail
+
+SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
+REPO_ROOT=$(cd "$SCRIPT_DIR/.." && pwd)
+
+BANDIT_ROOT="${BANDIT_ROOT:-$REPO_ROOT/build/bandit}"
+VENV_DIR=""
+REPORT_DIR=""
+TARGET=""
+CLEAN=1
+SKIP_INSTALL=0
+STRICT=0
+
+log_info() {
+    printf '[bandit] %s\n' "$1"
+}
+
+log_error() {
+    printf '[bandit] ERROR: %s\n' "$1" >&2
+}
+
+die() {
+    log_error "$1"
+    exit 1
+}
+
+show_help() {
+    cat << EOF
+Run a local Bandit scan for AgenticROS.
+
+USAGE:
+    $0 [options]
+
+OPTIONS:
+    --target PATH      Scan target (default: ros2_ws/src)
+    --venv-dir PATH    Python virtual environment path (default: build/bandit/.venv)
+    --report-dir PATH  Report directory (default: build/bandit/report)
+    --no-clean         Reuse any existing report output
+    --skip-install     Reuse the existing Bandit installation in the venv
+    --strict           Exit non-zero when Bandit reports findings
+    -h, --help         Show this help message
+EOF
+}
+
+parse_args() {
+    while [[ $# -gt 0 ]]; do
+        case "$1" in
+            --)
+                shift
+                ;;
+            --target)
+                [[ $# -ge 2 ]] || die "Missing value for --target"
+                TARGET="$2"
+                shift 2
+                ;;
+            --venv-dir)
+                [[ $# -ge 2 ]] || die "Missing value for --venv-dir"
+                VENV_DIR="$2"
+                shift 2
+                ;;
+            --report-dir)
+                [[ $# -ge 2 ]] || die "Missing value for --report-dir"
+                REPORT_DIR="$2"
+                shift 2
+                ;;
+            --no-clean)
+                CLEAN=0
+                shift
+                ;;
+            --skip-install)
+                SKIP_INSTALL=1
+                shift
+                ;;
+            --strict)
+                STRICT=1
+                shift
+                ;;
+            -h|--help)
+                show_help
+                exit 0
+                ;;
+            *)
+                die "Unknown argument: $1"
+                ;;
+        esac
+    done
+}
+
+ensure_python() {
+    [[ -x /usr/bin/python3 ]] || die "Required interpreter '/usr/bin/python3' was not found."
+}
+
+ensure_venv() {
+    if [[ -x "$VENV_DIR/bin/python" ]]; then
+        return
+    fi
+
+    log_info "Creating Python virtual environment at $VENV_DIR"
+    /usr/bin/python3 -m venv "$VENV_DIR"
+}
+
+ensure_bandit() {
+    if [[ $SKIP_INSTALL -eq 1 && ! -x "$VENV_DIR/bin/bandit" ]]; then
+        die "--skip-install was requested, but Bandit is not installed in $VENV_DIR"
+    fi
+
+    if [[ $SKIP_INSTALL -eq 1 ]]; then
+        log_info "Reusing existing Bandit installation in $VENV_DIR"
+        return
+    fi
+
+    if [[ -x "$VENV_DIR/bin/bandit" ]]; then
+        log_info "Bandit already installed in $VENV_DIR"
+        return
+    fi
+
+    log_info "Installing Bandit into $VENV_DIR"
+    "$VENV_DIR/bin/python" -m pip install --upgrade pip >/dev/null
+    "$VENV_DIR/bin/python" -m pip install bandit
+}
+
+run_bandit() {
+    local -a scan_args=(
+        -r "$TARGET"
+        -x "$TARGET/**/__pycache__/*"
+    )
+    local json_status=0
+    local text_status=0
+
+    log_info "Writing JSON report"
+    set +e
+    "$VENV_DIR/bin/bandit" "${scan_args[@]}" -f json -o "$REPORT_DIR/bandit.json"
+    json_status=$?
+    set -e
+
+    log_info "Writing text report"
+    set +e
+    "$VENV_DIR/bin/bandit" "${scan_args[@]}" -f txt -o "$REPORT_DIR/bandit.txt"
+    text_status=$?
+    set -e
+
+    if [[ $json_status -ne 0 ]]; then
+        BANDIT_STATUS=$json_status
+    else
+        BANDIT_STATUS=$text_status
+    fi
+}
+
+main() {
+    parse_args "$@"
+
+    TARGET="${TARGET:-$REPO_ROOT/ros2_ws/src}"
+    VENV_DIR="${VENV_DIR:-$BANDIT_ROOT/.venv}"
+    REPORT_DIR="${REPORT_DIR:-$BANDIT_ROOT/report}"
+
+    [[ -d "$TARGET" ]] || die "Target path '$TARGET' does not exist."
+
+    ensure_python
+    mkdir -p "$BANDIT_ROOT"
+
+    if [[ $CLEAN -eq 1 ]]; then
+        rm -rf "$REPORT_DIR"
+    fi
+
+    mkdir -p "$REPORT_DIR"
+    ensure_venv
+    ensure_bandit
+    run_bandit
+
+    log_info "Bandit scan complete"
+    log_info "Target: $TARGET"
+    log_info "Text report: $REPORT_DIR/bandit.txt"
+    log_info "JSON report: $REPORT_DIR/bandit.json"
+
+    if [[ ${BANDIT_STATUS:-0} -ne 0 ]]; then
+        log_info "Bandit reported findings"
+        if [[ $STRICT -eq 1 ]]; then
+            exit "$BANDIT_STATUS"
+        fi
+    fi
+}
+
+main "$@"
