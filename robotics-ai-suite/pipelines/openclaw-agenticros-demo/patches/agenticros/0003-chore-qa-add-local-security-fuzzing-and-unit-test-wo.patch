+import test from "node:test";
+import assert from "node:assert/strict";
+
+import {
+  cameraSnapshotFromPlainMessage,
+  coerceRosImageDataToBuffer,
+  mimeTypeForSnapshotBase64,
+} from "../../packages/ros-camera/src/index.ts";
+
+test("coerceRosImageDataToBuffer unwraps nested JSON Buffer payloads", () => {
+  const bytes = [0, 255, 16, 32, 48];
+  const wrapped = {
+    data: {
+      type: "Buffer",
+      data: bytes,
+    },
+  };
+
+  const result = coerceRosImageDataToBuffer(wrapped);
+  assert.equal(Buffer.isBuffer(result), true);
+  assert.deepEqual([...result], bytes);
+});
+
+test("cameraSnapshotFromPlainMessage encodes raw rgb8 images to PNG", () => {
+  const message = {
+    encoding: "rgb8",
+    width: 1,
+    height: 1,
+    step: 3,
+    data: [255, 0, 0],
+  };
+
+  const snapshot = cameraSnapshotFromPlainMessage("Image", message);
+
+  assert.equal(snapshot.formatLabel, "png");
+  assert.equal(snapshot.width, 1);
+  assert.equal(snapshot.height, 1);
+  assert.equal(mimeTypeForSnapshotBase64(snapshot.dataBase64, snapshot.formatLabel), "image/png");
+  assert.equal(Buffer.from(snapshot.dataBase64, "base64").subarray(0, 8).toString("hex"), "89504e470d0a1a0a");
+});
+
+test("cameraSnapshotFromPlainMessage preserves compressed image payload bytes", () => {
+  const pngBytes = Buffer.from("89504e470d0a1a0a0000000d49484452", "hex");
+  const snapshot = cameraSnapshotFromPlainMessage("CompressedImage", {
+    format: "png",
+    data: { type: "Buffer", data: [...pngBytes] },
+  });
+
+  assert.equal(snapshot.formatLabel, "png");
+  assert.equal(snapshot.dataBase64, pngBytes.toString("base64"));
+  assert.equal(mimeTypeForSnapshotBase64(snapshot.dataBase64, snapshot.formatLabel), "image/png");
+});
