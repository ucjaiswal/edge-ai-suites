@@ -0,0 +1,175 @@
+#!/bin/bash
+
+set -euo pipefail
+
+SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
+REPO_ROOT=$(cd "$SCRIPT_DIR/.." && pwd)
+
+MODE="build"
+COVERITY_ROOT="${COVERITY_ROOT:-$REPO_ROOT/build/coverity}"
+COVERITY_CONFIG=""
+IDIR=""
+REPORT_DIR=""
+CLEAN=1
+
+log_info() {
+    printf '[coverity] %s\n' "$1"
+}
+
+log_error() {
+    printf '[coverity] ERROR: %s\n' "$1" >&2
+}
+
+die() {
+    log_error "$1"
+    exit 1
+}
+
+require_tool() {
+    command -v "$1" >/dev/null 2>&1 || die "Required tool '$1' was not found in PATH."
+}
+
+show_help() {
+    cat << EOF
+Run a local Coverity scan for AgenticROS.
+
+USAGE:
+    $0 [options]
+
+OPTIONS:
+    --mode MODE        Capture mode: build (default) or fs
+    --idir PATH        Intermediate directory (default: build/coverity/idir)
+    --report-dir PATH  Report directory (default: build/coverity/report)
+    --no-clean         Reuse any existing Coverity output
+    -h, --help         Show this help message
+
+MODES:
+    build              Capture the recursive pnpm build
+    fs                 Filesystem capture when cov-build supports --fs-capture-search
+EOF
+}
+
+parse_args() {
+    while [[ $# -gt 0 ]]; do
+        case "$1" in
+            --)
+                shift
+                ;;
+            --mode)
+                [[ $# -ge 2 ]] || die "Missing value for --mode"
+                MODE="$2"
+                shift 2
+                ;;
+            --idir)
+                [[ $# -ge 2 ]] || die "Missing value for --idir"
+                IDIR="$2"
+                shift 2
+                ;;
+            --report-dir)
+                [[ $# -ge 2 ]] || die "Missing value for --report-dir"
+                REPORT_DIR="$2"
+                shift 2
+                ;;
+            --no-clean)
+                CLEAN=0
+                shift
+                ;;
+            -h|--help)
+                show_help
+                exit 0
+                ;;
+            *)
+                die "Unknown argument: $1"
+                ;;
+        esac
+    done
+}
+
+run_fs_capture() {
+    PATH="$PATH" cov-build --help | grep -q -- '--fs-capture-search' || \
+        die "The installed Coverity version does not support filesystem capture. Use --mode build instead."
+
+    local -a capture_args=()
+    local -a capture_roots=(
+        "$REPO_ROOT/packages"
+        "$REPO_ROOT/scripts"
+        "$REPO_ROOT/examples"
+        "$REPO_ROOT/ros2_ws/src"
+    )
+
+    local root
+    for root in "${capture_roots[@]}"; do
+        if [[ -d "$root" ]]; then
+            capture_args+=(--fs-capture-search "$root")
+        fi
+    done
+
+    log_info "Capturing source tree with Coverity filesystem capture"
+    cov-build --config "$COVERITY_CONFIG" --dir "$IDIR" "${capture_args[@]}" --no-command
+}
+
+run_build_capture() {
+    require_tool pnpm
+    log_info "Capturing recursive pnpm build"
+    cov-build --config "$COVERITY_CONFIG" --dir "$IDIR" pnpm build
+}
+
+ensure_coverity_config() {
+    if [[ -f "$COVERITY_CONFIG" ]]; then
+        return
+    fi
+
+    mkdir -p "$(dirname "$COVERITY_CONFIG")"
+    log_info "Generating Coverity config for TypeScript and JavaScript capture"
+    cov-configure --config "$COVERITY_CONFIG" --typescript
+}
+
+main() {
+    parse_args "$@"
+
+    case "$MODE" in
+        fs|build)
+            ;;
+        *)
+            die "Unsupported mode '$MODE'. Use 'fs' or 'build'."
+            ;;
+    esac
+
+    IDIR="${IDIR:-$COVERITY_ROOT/idir}"
+    REPORT_DIR="${REPORT_DIR:-$COVERITY_ROOT/report}"
+    COVERITY_CONFIG="${COVERITY_CONFIG:-$COVERITY_ROOT/coverity_config.xml}"
+
+    require_tool cov-build
+    require_tool cov-configure
+    require_tool cov-analyze
+    require_tool cov-format-errors
+
+    if [[ $CLEAN -eq 1 ]]; then
+        rm -rf "$IDIR" "$REPORT_DIR"
+    fi
+
+    mkdir -p "$IDIR" "$REPORT_DIR"
+    ensure_coverity_config
+
+    if [[ "$MODE" == "fs" ]]; then
+        run_fs_capture
+    else
+        run_build_capture
+    fi
+
+    log_info "Running Coverity analysis"
+    cov-analyze --config "$COVERITY_CONFIG" --dir "$IDIR" --all
+
+    log_info "Writing JSON report"
+    cov-format-errors --config "$COVERITY_CONFIG" --dir "$IDIR" --json-output-v7 "$REPORT_DIR/errors.json"
+
+    log_info "Writing HTML report"
+    cov-format-errors --config "$COVERITY_CONFIG" --dir "$IDIR" --html-output "$REPORT_DIR/html"
+
+    log_info "Coverity analysis complete"
+    log_info "Config file: $COVERITY_CONFIG"
+    log_info "JSON report: $REPORT_DIR/errors.json"
+    log_info "HTML report: $REPORT_DIR/html/index.html"
+}
+
+main "$@"
