+import argparse
+import math
+import time
+from typing import Dict
+
+import rclpy
+from geometry_msgs.msg import Twist
+from nav_msgs.msg import Odometry
+from rclpy.node import Node
+from std_msgs.msg import Float64
+
+
+ARM_JOINTS = [
+    "arm_lj1",
+    "arm_lj2",
+    "arm_lj3",
+    "arm_lj4",
+    "arm_lj5",
+    "arm_lj6",
+    "arm_lj7",
+    "arm_rj1",
+    "arm_rj2",
+    "arm_rj3",
+    "arm_rj4",
+    "arm_rj5",
+    "arm_rj6",
+    "arm_rj7",
+]
+
+
+def _pose_from_arm_values(values: list[float]) -> Dict[str, float]:
+    if len(values) != len(ARM_JOINTS):
+        raise ValueError(f"Expected {len(ARM_JOINTS)} values, got {len(values)}")
+    return {joint: value for joint, value in zip(ARM_JOINTS, values)}
+
+
+ARM_POSES = {
+    "home": _pose_from_arm_values([
+        -math.pi / 2,
+        math.pi / 2,
+        0.0,
+        -2.0944,
+        0.0,
+        -1.0472,
+        0.0,
+        math.pi / 2,
+        math.pi / 2,
+        0.0,
+        -2.0944,
+        0.0,
+        1.0472,
+        0.0,
+    ]),
+    "cross": _pose_from_arm_values([
+        -0.2,
+        1.0,
+        -1.0,
+        -1.8,
+        0.7,
+        0.8,
+        1.2,
+        0.2,
+        1.0,
+        1.0,
+        -1.8,
+        -0.7,
+        -0.8,
+        -1.2,
+    ]),
+}
+
+
+class JakaMotionSmokeTest(Node):
+    def __init__(self) -> None:
+        super().__init__("jaka_motion_smoke_test")
+        self._cmd_vel_pub = self.create_publisher(Twist, "/cmd_vel", 10)
+        self._joint_pubs = {
+            joint: self.create_publisher(Float64, f"/jaka_cargo/joints/{joint}/cmd_pos", 10)
+            for joint in ARM_JOINTS
+        }
+        self._odom_sub = self.create_subscription(Odometry, "/odom", self._on_odom, 10)
+        self._last_odom = None
+
+    def _on_odom(self, msg: Odometry) -> None:
+        self._last_odom = msg
+
+    def wait_for_odom(self, timeout_sec: float) -> bool:
+        start = time.time()
+        while rclpy.ok() and (time.time() - start) < timeout_sec:
+            rclpy.spin_once(self, timeout_sec=0.1)
+            if self._last_odom is not None:
+                return True
+        return False
+
+    def publish_base(self, linear_x: float, angular_z: float, duration: float, hz: float = 20.0) -> None:
+        steps = max(1, int(duration * hz))
+        msg = Twist()
+        msg.linear.x = float(linear_x)
+        msg.angular.z = float(angular_z)
+        for _ in range(steps):
+            self._cmd_vel_pub.publish(msg)
+            rclpy.spin_once(self, timeout_sec=0.0)
+            time.sleep(1.0 / hz)
+
+        stop = Twist()
+        for _ in range(5):
+            self._cmd_vel_pub.publish(stop)
+            rclpy.spin_once(self, timeout_sec=0.0)
+            time.sleep(0.05)
+
+    def publish_arm_pose(self, pose_name: str, duration: float, hz: float = 20.0) -> None:
+        if pose_name not in ARM_POSES:
+            raise ValueError(f"Unknown pose '{pose_name}'. Available: {', '.join(sorted(ARM_POSES))}")
+
+        pose = ARM_POSES[pose_name]
+        steps = max(1, int(duration * hz))
+        for _ in range(steps):
+            for joint, value in pose.items():
+                msg = Float64()
+                msg.data = float(value)
+                self._joint_pubs[joint].publish(msg)
+            rclpy.spin_once(self, timeout_sec=0.0)
+            time.sleep(1.0 / hz)
+
+    def odom_xy(self):
+        if self._last_odom is None:
+            return None
+        p = self._last_odom.pose.pose.position
+        return (float(p.x), float(p.y))
+
+
+def _build_parser() -> argparse.ArgumentParser:
+    parser = argparse.ArgumentParser(description="Scripted JAKA base+arm smoke test for Gazebo empty-world launch.")
+    parser.add_argument("--base-linear", type=float, default=0.5, help="Base linear x velocity (m/s).")
+    parser.add_argument("--base-angular", type=float, default=0.0, help="Base angular z velocity (rad/s).")
+    parser.add_argument("--base-duration", type=float, default=10.0, help="Base command duration (s).")
+    parser.add_argument("--arm-duration", type=float, default=2.0, help="Duration for each arm pose publish stage (s).")
+    parser.add_argument("--hold", type=float, default=1.0, help="Hold time between arm poses (s).")
+    parser.add_argument("--odom-timeout", type=float, default=8.0, help="Seconds to wait for /odom before running.")
+    return parser
+
+
+def main(argv=None) -> int:
+    args = _build_parser().parse_args(argv)
+
+    rclpy.init(args=None)
+    node = JakaMotionSmokeTest()
+
+    try:
+        node.get_logger().info("Waiting for /odom...")
+        has_odom = node.wait_for_odom(args.odom_timeout)
+        if not has_odom:
+            node.get_logger().warn("/odom not received. Base displacement report will be unavailable.")
+
+        start_xy = node.odom_xy()
+
+        node.get_logger().info("Arm test: pose=home")
+        node.publish_arm_pose("home", duration=args.arm_duration)
+        time.sleep(max(0.0, args.hold))
+
+        node.get_logger().info("Arm test: pose=cross")
+        node.publish_arm_pose("cross", duration=args.arm_duration)
+        time.sleep(max(0.0, args.hold))
+
+        node.get_logger().info("Arm test: pose=home")
+        node.publish_arm_pose("home", duration=args.arm_duration)
+
+        node.get_logger().info(
+            f"Base test: linear={args.base_linear:.3f} m/s angular={args.base_angular:.3f} rad/s duration={args.base_duration:.2f}s"
+        )
+        node.publish_base(args.base_linear, args.base_angular, args.base_duration)
+
+        for _ in range(10):
+            rclpy.spin_once(node, timeout_sec=0.05)
+
+        end_xy = node.odom_xy()
+        if start_xy is not None and end_xy is not None:
+            dx = end_xy[0] - start_xy[0]
+            dy = end_xy[1] - start_xy[1]
+            dist = math.hypot(dx, dy)
+            node.get_logger().info(
+                f"Base displacement from odom: dx={dx:.3f} m dy={dy:.3f} m distance={dist:.3f} m"
+            )
+            if dist < 0.08:
+                node.get_logger().warn(
+                    "Base movement was small enough that it may be hard to notice in Gazebo GUI. "
+                    "Try a longer base duration if you need a more obvious motion in the scene."
+                )
+        else:
+            node.get_logger().warn("Could not compute base displacement because /odom was not available.")
+
+        node.get_logger().info("JAKA motion smoke test completed.")
+        return 0
+    finally:
+        node.destroy_node()
+        rclpy.shutdown()
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
