+#!/usr/bin/env bash
+set -euo pipefail
+
+ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
+WS_DIR="$ROOT_DIR/ros2_ws"
+CLEANUP="$ROOT_DIR/scripts/cleanup_sim_processes.sh"
+
+TIMEOUT_SECONDS="${1:-90}"
+
+cleanup_on_exit() {
+  "$CLEANUP" >/dev/null 2>&1 || true
+}
+trap cleanup_on_exit EXIT INT TERM
+
+"$CLEANUP"
+
+set +u
+source /opt/ros/jazzy/setup.bash
+cd "$WS_DIR"
+source install/setup.bash
+set -u
+
+timeout "$TIMEOUT_SECONDS" ros2 launch agenticros_bringup rosbridge_gazebo.launch.py \
+  robot_type:=jaka_kargo \
+  use_gazebo_gui:=false \
+  port:=9290 \
+  safe_physics_profile:=true
