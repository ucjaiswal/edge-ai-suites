+            DeclareLaunchArgument(
+                "lidar_update_rate",
+                default_value="10",
+                description="JAKA lidar update rate override (Hz) applied at spawn time.",
+            ),
+            DeclareLaunchArgument(
+                "jaka_linear_velocity_scale",
+                default_value="1.0",
+                description="AGV base linear odometry scale.",
+            ),
+            DeclareLaunchArgument(
+                "jaka_angular_velocity_scale",
+                default_value="0.5642857142857143",
+                description="AGV base angular odometry scale.",
+            ),
+            DeclareLaunchArgument(
+                "gazebo_gui_config",
