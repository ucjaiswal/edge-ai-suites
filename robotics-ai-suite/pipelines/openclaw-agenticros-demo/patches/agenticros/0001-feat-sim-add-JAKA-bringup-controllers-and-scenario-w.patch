+    bringup_share = get_package_share_directory("agenticros_bringup")
+    return str(Path(bringup_share) / "worlds" / "jaka_empty.world")
+
+
+def generate_launch_description():
+    rosbridge = IncludeLaunchDescription(
+        AnyLaunchDescriptionSource(
+            PathJoinSubstitution(
+                [
+                    FindPackageShare("rosbridge_server"),
+                    "launch",
+                    "rosbridge_websocket_launch.xml",
+                ]
+            )
+        ),
+        launch_arguments={
+            "port": LaunchConfiguration("port"),
+        }.items(),
+    )
+
+    gazebo_jaka_empty = IncludeLaunchDescription(
+        PythonLaunchDescriptionSource(
+            PathJoinSubstitution(
+                [
+                    FindPackageShare("agenticros_bringup"),
+                    "launch",
+                    "gazebo_small_warehouse.launch.py",
+                ]
+            )
+        ),
+        launch_arguments={
+            "robot_type": "jaka_kargo",
+            "warehouse_world": LaunchConfiguration("empty_world"),
+            "use_gazebo_gui": LaunchConfiguration("use_gazebo_gui"),
+            "robot_namespace": LaunchConfiguration("robot_namespace"),
+            "x_pose": LaunchConfiguration("x_pose"),
+            "y_pose": LaunchConfiguration("y_pose"),
+            "jaka_z_pose": LaunchConfiguration("jaka_z_pose"),
+            "disable_jaka_gazebo_sensors": LaunchConfiguration("disable_jaka_gazebo_sensors"),
+            "camera_width": LaunchConfiguration("camera_width"),
+            "camera_height": LaunchConfiguration("camera_height"),
+            "camera_update_rate": LaunchConfiguration("camera_update_rate"),
+            "enable_camera_2": LaunchConfiguration("enable_camera_2"),
+            "lidar_update_rate": LaunchConfiguration("lidar_update_rate"),
+            "jaka_linear_velocity_scale": LaunchConfiguration("jaka_linear_velocity_scale"),
+            "jaka_angular_velocity_scale": LaunchConfiguration("jaka_angular_velocity_scale"),
+            "gazebo_gui_config": LaunchConfiguration("gazebo_gui_config"),
+            "gazebo_camera_pose": LaunchConfiguration("gazebo_camera_pose"),
+        }.items(),
+    )
+
+    return LaunchDescription(
+        [
+            DeclareLaunchArgument(
+                "port",
+                default_value="9090",
+                description="ROS bridge websocket port.",
+            ),
+            DeclareLaunchArgument(
+                "empty_world",
+                default_value=_default_empty_world_path(),
+                description="Absolute path to Gazebo empty world file.",
+            ),
+            DeclareLaunchArgument(
+                "use_gazebo_gui",
+                default_value="false",
+                description="Start Gazebo GUI client in addition to server.",
+            ),
+            DeclareLaunchArgument(
+                "robot_namespace",
+                default_value="",
+                description="Optional AgenticROS robot namespace for cmd_vel relay.",
+            ),
+            DeclareLaunchArgument(
+                "x_pose",
+                default_value="0.0",
