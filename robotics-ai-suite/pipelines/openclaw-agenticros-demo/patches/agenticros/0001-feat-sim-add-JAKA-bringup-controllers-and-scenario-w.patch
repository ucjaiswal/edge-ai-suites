+++ b/ros2_ws/capture_joints.py
@@ -0,0 +1,38 @@
+import rclpy
+from rclpy.node import Node
+from sensor_msgs.msg import JointState
+import sys
+
+TARGET_JOINTS = [
+    'body_j1', 'body_j2', 'body_j3', 'body_j4',
+    'arm_lj1', 'arm_lj2', 'arm_lj3', 'arm_lj4',
+    'arm_rj1', 'arm_rj2', 'arm_rj3', 'arm_rj4'
+]
+
+class JointSubscriber(Node):
+    def __init__(self):
+        super().__init__('joint_subscriber')
+        self.subscription = self.create_subscription(
+            JointState,
+            '/joint_states',
+            self.listener_callback,
+            10)
+        self.received = False
+
+    def listener_callback(self, msg):
+        joint_map = dict(zip(msg.name, msg.position))
+        results = []
+        for name in TARGET_JOINTS:
+            val = joint_map.get(name, float('nan'))
+            results.append(f"{name}={val:.6f}")
+        print("; ".join(results))
+        self.received = True
+        rclpy.shutdown()
+
+def main():
+    rclpy.init()
+    node = JointSubscriber()
+    rclpy.spin(node)
+
+if __name__ == '__main__':
+    main()
