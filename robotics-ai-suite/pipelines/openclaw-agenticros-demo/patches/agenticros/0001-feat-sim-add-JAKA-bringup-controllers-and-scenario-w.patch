+++ b/ros2_ws/src/agenticros_bringup/launch/sim8_small_warehouse_websocket.gzlaunch
@@ -0,0 +1,70 @@
+<?xml version='1.0'?>
+<!--
+Usage:
+  source /opt/ros/jazzy/setup.bash
+  cd /home/dev/agenticros/ros2_ws
+  gz launch src/agenticros_bringup/launch/sim8_small_warehouse_websocket.gzlaunch
+
+Optional args:
+  worldPath:=/absolute/path/to/world.world
+  wsPort:=9002
+  publicationHz:=30
+  maxConnections:=-1
+
+Example:
+  gz launch src/agenticros_bringup/launch/sim8_small_warehouse_websocket.gzlaunch \
+    worldPath:=/home/dev/agenticros/ros2_ws/src/aws-robomaker-small-warehouse-world/worlds/no_roof_small_warehouse/no_roof_small_warehouse.world \
+    wsPort:=9002
+-->
+<%
+  if !defined?(worldPath) || worldPath == nil || worldPath.empty?
+    worldPath = "/home/dev/agenticros/ros2_ws/src/aws-robomaker-small-warehouse-world/worlds/small_warehouse/small_warehouse.world"
+  end
+
+  if !defined?(wsPort) || wsPort == nil || wsPort.empty?
+    wsPort = "9002"
+  end
+
+  if !defined?(publicationHz) || publicationHz == nil || publicationHz.empty?
+    publicationHz = "30"
+  end
+
+  if !defined?(maxConnections) || maxConnections == nil || maxConnections.empty?
+    maxConnections = "-1"
+  end
+
+  awsRoot = File.expand_path("../..", File.dirname(worldPath))
+
+  # Ensure Gazebo can resolve nested file://models/... URIs used by AWS model SDFs.
+  extraResourcePaths = [awsRoot, File.join(awsRoot, "models")]
+  existingResourcePath = ENV["GZ_SIM_RESOURCE_PATH"].to_s
+  ENV["GZ_SIM_RESOURCE_PATH"] = ([existingResourcePath] + extraResourcePaths)
+    .reject { |p| p.nil? || p.empty? }
+    .join(":")
+
+  # Convert model:// URIs to absolute file:// URIs so this launch works
+  # without requiring external GZ_SIM_RESOURCE_PATH exports.
+  modelRoot = File.expand_path("../../models", File.dirname(worldPath))
+  worldText = File.read(worldPath)
+  worldText = worldText.gsub(/model:\/\/([A-Za-z0-9_.\-]+)/) do
+    "file://#{File.join(modelRoot, $1)}"
+  end
+
+  generatedWorldPath = "/tmp/sim8_small_warehouse_websocket_#{Process.pid}.world"
+  File.write(generatedWorldPath, worldText)
+%>
+<gz version='1.0'>
+  <plugin name="gz::launch::WebsocketServer"
+          filename="gz-launch-websocket-server">
+    <publication_hz><%= publicationHz %></publication_hz>
+    <port><%= wsPort %></port>
+    <max_connections><%= maxConnections %></max_connections>
+  </plugin>
+
+  <plugin name="gz::launch::SimServer"
+          filename="gz-launch-sim">
+    <world_file><%= generatedWorldPath %></world_file>
+    <run>true</run>
+    <levels>false</levels>
+  </plugin>
+</gz>
