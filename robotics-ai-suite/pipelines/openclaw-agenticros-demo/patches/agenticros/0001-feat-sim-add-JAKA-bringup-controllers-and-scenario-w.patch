diff --git a/ros2_ws/src/agenticros_bringup/agenticros_bringup/cmd_vel_to_stamped.py b/ros2_ws/src/agenticros_bringup/agenticros_bringup/cmd_vel_to_stamped.py
new file mode 100644
index 0000000..6f09c8f
--- /dev/null
+++ b/ros2_ws/src/agenticros_bringup/agenticros_bringup/cmd_vel_to_stamped.py
@@ -0,0 +1,44 @@
+#!/usr/bin/env python3
+"""Bridge Twist to TwistStamped on one topic for TurtleBot3 Gazebo."""
+
+import rclpy
+from rclpy.node import Node
+from geometry_msgs.msg import Twist, TwistStamped
+
+
+class CmdVelToStampedNode(Node):
+    def __init__(self) -> None:
+        super().__init__("agenticros_cmd_vel_to_stamped")
+        input_topic = self.declare_parameter("input_topic", "/cmd_vel_unstamped").get_parameter_value().string_value
+        output_topic = self.declare_parameter("output_topic", "/cmd_vel").get_parameter_value().string_value
+        frame_id = self.declare_parameter("frame_id", "base_link").get_parameter_value().string_value
+        self._frame_id = frame_id
+        self._pub = self.create_publisher(TwistStamped, output_topic, 10)
+        self.create_subscription(Twist, input_topic, self._on_twist, 10)
+        self.get_logger().info(
+            f"Bridging Twist {input_topic} -> TwistStamped {output_topic} (frame_id={frame_id})"
+        )
+
+    def _on_twist(self, msg: Twist) -> None:
+        stamped = TwistStamped()
+        stamped.header.stamp = self.get_clock().now().to_msg()
+        stamped.header.frame_id = self._frame_id
+        stamped.twist = msg
+        self._pub.publish(stamped)
+
+
+def main() -> None:
+    rclpy.init()
+    node = CmdVelToStampedNode()
+    try:
+        rclpy.spin(node)
+    except KeyboardInterrupt:
+        pass
+    finally:
+        node.destroy_node()
+        if rclpy.ok():
+            rclpy.shutdown()
+
+
+if __name__ == "__main__":
+    main()
diff --git a/ros2_ws/src/agenticros_bringup/agenticros_bringup/jaka_base_controller.py b/ros2_ws/src/agenticros_bringup/agenticros_bringup/jaka_base_controller.py
new file mode 100644
index 0000000..2b9c7bf
--- /dev/null
+++ b/ros2_ws/src/agenticros_bringup/agenticros_bringup/jaka_base_controller.py
@@ -0,0 +1,147 @@
+import math
+
+import rclpy
+from geometry_msgs.msg import Twist
+from nav_msgs.msg import Odometry
+from rclpy.node import Node
+from std_msgs.msg import Float64
+
+
+DEFAULT_LINEAR_VELOCITY_SCALE = 1.0
+DEFAULT_ANGULAR_VELOCITY_SCALE = 0.5642857142857143
+
+
+def _yaw_to_quaternion(yaw: float) -> tuple[float, float, float, float]:
+    half = yaw * 0.5
+    return (0.0, 0.0, math.sin(half), math.cos(half))
+
+
+class JakaBaseController(Node):
+    def __init__(self) -> None:
+        super().__init__("jaka_base_controller")
+
+        cmd_vel_topic = self.declare_parameter("cmd_vel_topic", "/cmd_vel").get_parameter_value().string_value
+        odom_topic = self.declare_parameter("odom_topic", "/odom").get_parameter_value().string_value
+        x_topic = self.declare_parameter("agv_x_topic", "/jaka_cargo/joints/agv_x/cmd_pos").get_parameter_value().string_value
+        y_topic = self.declare_parameter("agv_y_topic", "/jaka_cargo/joints/agv_y/cmd_pos").get_parameter_value().string_value
+        yaw_topic = self.declare_parameter("agv_yaw_topic", "/jaka_cargo/joints/agv_yaw/cmd_pos").get_parameter_value().string_value
+        update_rate = self.declare_parameter("update_rate_hz", 30.0).get_parameter_value().double_value
+        self._linear_scale = self.declare_parameter(
+            "linear_velocity_scale", DEFAULT_LINEAR_VELOCITY_SCALE
+        ).get_parameter_value().double_value
+        self._angular_scale = self.declare_parameter(
+            "angular_velocity_scale", DEFAULT_ANGULAR_VELOCITY_SCALE
+        ).get_parameter_value().double_value
+        self._max_integration_dt = self.declare_parameter("max_integration_dt", 0.2).get_parameter_value().double_value
+
+        self._x = self.declare_parameter("initial_x", 0.0).get_parameter_value().double_value
+        self._y = self.declare_parameter("initial_y", 0.0).get_parameter_value().double_value
+        self._yaw = self.declare_parameter("initial_yaw", 0.0).get_parameter_value().double_value
+
+        self._cmd_linear_x = 0.0
+        self._cmd_linear_y = 0.0
+        self._cmd_angular_z = 0.0
+        self._last_time = None
+
+        self._agv_x_pub = self.create_publisher(Float64, x_topic, 10)
+        self._agv_y_pub = self.create_publisher(Float64, y_topic, 10)
+        self._agv_yaw_pub = self.create_publisher(Float64, yaw_topic, 10)
+        self._odom_pub = self.create_publisher(Odometry, odom_topic, 10)
+        self.create_subscription(Twist, cmd_vel_topic, self._on_cmd_vel, 10)
+
+        period = 1.0 / max(update_rate, 1.0)
+        self.create_timer(period, self._on_timer)
+        self.get_logger().info(
+            "JAKA base controller: "
+            f"cmd_vel={cmd_vel_topic}, odom={odom_topic}, "
+            f"agv targets=({x_topic}, {y_topic}, {yaw_topic}), "
+            f"linear_velocity_scale={self._linear_scale:.4f}, angular_velocity_scale={self._angular_scale:.4f}, "
+            f"max_integration_dt={self._max_integration_dt:.3f}"
+        )
+
+    def _on_cmd_vel(self, msg: Twist) -> None:
+        self._cmd_linear_x = float(msg.linear.x)
+        self._cmd_linear_y = float(msg.linear.y)
+        self._cmd_angular_z = float(msg.angular.z)
+
+    def _on_timer(self) -> None:
+        now = self.get_clock().now()
+        if self._last_time is None:
+            self._last_time = now
+            self._publish_targets()
+            self._publish_odom(now)
+            return
+
+        dt = (now - self._last_time).nanoseconds / 1e9
+        self._last_time = now
+        if dt <= 0.0:
+            self._publish_targets()
+            self._publish_odom(now)
+            return
+        if dt > self._max_integration_dt:
+            # Ignore discontinuities from /clock jumps to keep integration stable.
+            self.get_logger().warn(
+                f"Skipping integration step with large dt={dt:.3f}s (max {self._max_integration_dt:.3f}s)",
+                throttle_duration_sec=2.0,
+            )
+            self._publish_targets()
+            self._publish_odom(now)
+            return
+
+        effective_linear_x = self._cmd_linear_x * self._linear_scale
+        effective_linear_y = self._cmd_linear_y * self._linear_scale
+        effective_angular_z = self._cmd_angular_z * self._angular_scale
+
+        cos_yaw = math.cos(self._yaw)
+        sin_yaw = math.sin(self._yaw)
+        self._x += (effective_linear_x * cos_yaw - effective_linear_y * sin_yaw) * dt
+        self._y += (effective_linear_x * sin_yaw + effective_linear_y * cos_yaw) * dt
+        self._yaw += effective_angular_z * dt
+        self._yaw = math.atan2(math.sin(self._yaw), math.cos(self._yaw))
+
+        self._publish_targets()
+        self._publish_odom(now)
+
+    def _publish_targets(self) -> None:
+        for pub, value in (
+            (self._agv_x_pub, self._x),
+            (self._agv_y_pub, self._y),
+            (self._agv_yaw_pub, self._yaw),
+        ):
+            msg = Float64()
+            msg.data = float(value)
+            pub.publish(msg)
+
+    def _publish_odom(self, now) -> None:
+        odom = Odometry()
+        odom.header.stamp = now.to_msg()
+        odom.header.frame_id = "odom"
+        odom.child_frame_id = "base_link"
+        odom.pose.pose.position.x = float(self._x)
+        odom.pose.pose.position.y = float(self._y)
+        qx, qy, qz, qw = _yaw_to_quaternion(self._yaw)
+        odom.pose.pose.orientation.x = qx
+        odom.pose.pose.orientation.y = qy
+        odom.pose.pose.orientation.z = qz
+        odom.pose.pose.orientation.w = qw
+        odom.twist.twist.linear.x = float(self._cmd_linear_x * self._linear_scale)
+        odom.twist.twist.linear.y = float(self._cmd_linear_y * self._linear_scale)
+        odom.twist.twist.angular.z = float(self._cmd_angular_z * self._angular_scale)
+        self._odom_pub.publish(odom)
+
+
+def main() -> None:
+    rclpy.init()
+    node = JakaBaseController()
+    try:
+        rclpy.spin(node)
+    except KeyboardInterrupt:
+        pass
+    finally:
+        node.destroy_node()
+        if rclpy.ok():
+            rclpy.shutdown()
+
+
+if __name__ == "__main__":
+    main()
