+#!/bin/bash
+source /opt/ros/jazzy/setup.bash
+cd /home/dev/agenticros/ros2_ws
+. install/setup.bash
+
+run_scenario() {
+    local NAME=$1
+    local EXTRA_ARGS=$2
+    local TOPICS=($3)
+    echo "--- Scenario $NAME ---"
+    /home/dev/agenticros/scripts/cleanup_sim_processes.sh > /dev/null 2>&1
+    
+    ros2 launch agenticros_bringup rosbridge_gazebo.launch.py robot_type:=jaka_kargo use_gazebo_gui:=false $EXTRA_ARGS > /tmp/launch.log 2>&1 &
+    LPID=$!
+
+    echo "Waiting for launch..."
+    for i in {1..30}; do
+        if ros2 topic list | grep -q "/clock"; then break; fi
+        sleep 2
+    done
+
+    # Additional wait for images if baseline
+    if [[ "$EXTRA_ARGS" != *"disable_jaka_gazebo_sensors:=true"* ]]; then
+      for i in {1..20}; do
+          if ros2 topic list | grep -q "/camera_1/image_raw"; then break; fi
+          sleep 2
+      done
+    fi
+
+    for topic in "${TOPICS[@]}"; do
+        echo -n "$topic: "
+        timeout 10s ros2 topic hz $topic | grep "average rate:" || echo "Topic not found or no data"
+    done
+    
+    if [[ "$EXTRA_ARGS" == *"disable_jaka_gazebo_sensors:=true"* ]]; then
+        echo -n "Check cameras: "
+        ros2 topic list | grep -E '/camera_1/image_raw|/camera_2/image_raw' || echo "No camera topics"
+    fi
+
+    kill $LPID
+    /home/dev/agenticros/scripts/cleanup_sim_processes.sh > /dev/null 2>&1
+    sleep 5
+}
+
+run_scenario "A (Baseline)" "" "/camera_1/image_raw /camera_2/image_raw /odom /clock"
+run_scenario "B (No Sensors)" "disable_jaka_gazebo_sensors:=true" "/odom /clock"
+run_scenario "C (Baseline Redux)" "" "/camera_1/image_raw /odom /clock"
diff --git a/scripts/cleanup_sim_processes.sh b/scripts/cleanup_sim_processes.sh
new file mode 100755
index 0000000..b21be66
--- /dev/null
+++ b/scripts/cleanup_sim_processes.sh
@@ -0,0 +1,34 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+# Cleans Gazebo and ROS simulation processes used by the bringup tests.
+# Includes ROS 1 style process names as well because some environments still spawn them.
+# Also catches lingering agenticros_bringup Python nodes launched from install/ paths.
+PATTERN="ros2 launch agenticros_bringup rosbridge_gazebo.launch.py|gz sim|gazebo|ign gazebo|ros_gz_sim|parameter_bridge|image_bridge|rosbridge_websocket|rosapi_node|robot_state_publisher|joint_state_publisher|joint_state_publisher_gui|rviz2|static_transform_publisher|ros2-daemon|ros2cli\.daemon\.daemonize|roscore|rosmaster|rosout|roslaunch|rosrun|agenticros_bringup/.*/(jaka_base_controller|cmd_vel_relay|cmd_vel_to_stamped)|/agenticros_bringup/(jaka_base_controller|cmd_vel_relay|cmd_vel_to_stamped)([[:space:]]|$)|(^|[[:space:]/])ros([[:space:]]|$)"
+
+term_kill() {
+  pkill -f "$PATTERN" || true
+}
+
+force_kill() {
+  pkill -9 -f "$PATTERN" || true
+}
+
+show_remaining() {
+  pgrep -af "$PATTERN" || true
+}
+
+term_kill
+sleep 1
+if pgrep -af "$PATTERN" >/dev/null 2>&1; then
+  force_kill
+  sleep 1
+fi
+
+if pgrep -af "$PATTERN" >/dev/null 2>&1; then
+  echo "Cleanup incomplete: some processes are still alive"
+  show_remaining
+  exit 1
+fi
+
+echo "Simulation cleanup complete: no matching Gazebo/ROS test processes remain"
