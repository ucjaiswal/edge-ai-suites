+from launch.actions import DeclareLaunchArgument, ExecuteProcess, IncludeLaunchDescription, OpaqueFunction, TimerAction
 from launch.launch_description_sources import AnyLaunchDescriptionSource, PythonLaunchDescriptionSource
 from launch.substitutions import LaunchConfiguration, PathJoinSubstitution
 from launch_ros.substitutions import FindPackageShare
 
 
+def _resolve_world_path_from_name(world_name: str) -> str:
+    name = world_name.strip().lower()
+
+    if name == "jaka_empty":
+        bringup_share = Path(get_package_share_directory("agenticros_bringup"))
+        return str(bringup_share / "worlds" / "jaka_empty.world")
+
+    if name == "no_roof_small_warehouse":
+        aws_share = Path(get_package_share_directory("aws_robomaker_small_warehouse_world"))
+        return str(aws_share / "worlds" / "no_roof_small_warehouse" / "no_roof_small_warehouse.world")
+
+    if name == "small_warehouse":
+        return ""
+
+    if name == "turtlebot3_world":
+        tb3_share = Path(get_package_share_directory("turtlebot3_gazebo"))
+        return str(tb3_share / "worlds" / "turtlebot3_world.world")
+
+    raise RuntimeError(
+        "world_name must be 'jaka_empty', 'no_roof_small_warehouse', 'small_warehouse', or 'turtlebot3_world'"
+    )
+
+
+def _maybe_start_gz_websocket_sidecar(context, *args, **kwargs):
+    enabled = LaunchConfiguration("enable_gz_websocket_sidecar").perform(context).strip().lower() == "true"
+    if not enabled:
+        return []
+
+    gzlaunch_path = Path(__file__).resolve().parent / "sim8_websocket_only.gzlaunch"
+    ws_port = LaunchConfiguration("gz_websocket_port").perform(context)
+    publication_hz = LaunchConfiguration("gz_websocket_publication_hz").perform(context)
+    max_connections = LaunchConfiguration("gz_websocket_max_connections").perform(context)
+    verbose = LaunchConfiguration("gz_websocket_sidecar_verbose").perform(context)
+    start_delay_s = float(LaunchConfiguration("gz_websocket_sidecar_start_delay_s").perform(context))
+    respawn = LaunchConfiguration("gz_websocket_sidecar_respawn").perform(context).strip().lower() == "true"
+    respawn_delay_s = float(LaunchConfiguration("gz_websocket_sidecar_respawn_delay_s").perform(context))
+
+    sidecar = ExecuteProcess(
+        cmd=[
+            "bash",
+            "-lc",
+            (
+                "source /opt/ros/jazzy/setup.bash && "
+                f"GZ_VERBOSE={verbose} gz launch -v {verbose} {gzlaunch_path} "
+                f"wsPort:={ws_port} publicationHz:={publication_hz} maxConnections:={max_connections}"
+            ),
+        ],
+        output="screen",
+        respawn=respawn,
+        respawn_delay=respawn_delay_s,
+    )
+
+    if start_delay_s > 0.0:
+        return [TimerAction(period=start_delay_s, actions=[sidecar])]
+
+    return [sidecar]
+
+
