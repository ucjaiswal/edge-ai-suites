+"""Gazebo world launcher for JAKA Kargo or TurtleBot3 with optional namespace relay.
+
+This launch starts Gazebo server (and optional GUI) with a configurable world,
+then spawns either:
+- JAKA Kargo (robot_state_publisher + ros_gz_sim create from robot_description)
+- TurtleBot3 (upstream turtlebot3_gazebo spawn + robot_state_publisher)
+
+robot_type:
+- jaka_kargo
+- turtlebot3
+"""
+
+import os
+import re
+import tempfile
+from pathlib import Path
+
+from ament_index_python.packages import PackageNotFoundError, get_package_share_directory
+from launch import LaunchDescription
+from launch.actions import AppendEnvironmentVariable, DeclareLaunchArgument, IncludeLaunchDescription, LogInfo, OpaqueFunction, SetEnvironmentVariable, TimerAction
+from launch.conditions import IfCondition
+from launch.launch_description_sources import PythonLaunchDescriptionSource
+from launch.substitutions import LaunchConfiguration, PathJoinSubstitution, PythonExpression
+from launch_ros.actions import Node
+from launch_ros.parameter_descriptions import ParameterValue
+from launch_ros.substitutions import FindPackageShare
+
+
+def _resolve_aws_world_root() -> Path | None:
+    try:
+        return Path(get_package_share_directory("aws_robomaker_small_warehouse_world"))
+    except PackageNotFoundError:
+        pass
+
+    this_file = Path(__file__).resolve()
+    source_candidates = [
+        this_file.parents[2] / "aws-robomaker-small-warehouse-world",
+        this_file.parents[5] / "src" / "aws-robomaker-small-warehouse-world",
+    ]
+    for source_candidate in source_candidates:
+        if source_candidate.exists():
+            return source_candidate
+
+    return None
+
+
+def _default_warehouse_world_path() -> str:
+    aws_root = _resolve_aws_world_root()
+    if aws_root is None:
+        return ""
+    return str(aws_root / "worlds" / "small_warehouse" / "small_warehouse.world")
+
+
+def _resolve_jaka_resource_roots() -> list[Path]:
+    roots: list[Path] = []
+
+    try:
+        jaka_share = Path(get_package_share_directory("jaka_kargo_description"))
+        roots.append(jaka_share.parent)
+    except PackageNotFoundError:
+        pass
+
+    this_file = Path(__file__).resolve()
+    source_candidates = [
+        this_file.parents[2],
+        this_file.parents[5] / "src",
+    ]
+    for candidate in source_candidates:
+        if (candidate / "jaka_kargo_description").exists():
+            roots.append(candidate)
+
+    deduped: list[Path] = []
+    seen: set[str] = set()
+    for root in roots:
+        key = str(root)
+        if key in seen:
+            continue
+        seen.add(key)
+        deduped.append(root)
+
+    return deduped
+
+
+def _rewrite_world_model_uris_to_file(world_path: str, enabled: bool, aws_root: Path | None) -> str:
+    if not enabled or aws_root is None:
+        return world_path
+
+    world_file = Path(world_path)
+    if not world_file.exists() or not world_file.is_file():
+        return world_path
+
+    world_text = world_file.read_text(encoding="utf-8")
+    model_root = aws_root / "models"
+
+    rewritten = re.sub(
+        r"model://([A-Za-z0-9_.\-]+)",
+        lambda m: f"file://{model_root / m.group(1)}",
+        world_text,
+    )
+
+    if rewritten == world_text:
+        return world_path
+
+    fd, tmp_path = tempfile.mkstemp(prefix="aws_world_file_uri_", suffix=".world")
+    with os.fdopen(fd, "w", encoding="utf-8") as patched:
+        patched.write(rewritten)
+    return tmp_path
+
+
+def _ensure_world_plugins(world_path: str) -> str:
+    world_file = Path(world_path)
+    if not world_file.exists() or not world_file.is_file():
+        return world_path
+
+    world_text = world_file.read_text(encoding="utf-8")
+    if "</world>" not in world_text:
+        return world_path
+
+    def _force_dart_bullet_physics(text: str) -> str:
+        physics_match = re.search(r"<physics[^>]*>.*?</physics>", text, flags=re.DOTALL)
+        if physics_match is None:
+            return text
+
+        physics_block = physics_match.group(0)
+        patched_block = re.sub(r'type="ode"', 'type="dart"', physics_block, count=1)
+
+        dart_match = re.search(r"<dart>.*?</dart>", patched_block, flags=re.DOTALL)
+        if dart_match is not None:
+            dart_block = dart_match.group(0)
+            if "<collision_detector>" in dart_block:
+                dart_block = re.sub(
+                    r"<collision_detector>[^<]+</collision_detector>",
+                    "<collision_detector>bullet</collision_detector>",
+                    dart_block,
+                    count=1,
+                )
+            else:
+                dart_block = dart_block.replace(
+                    "</dart>",
+                    "\n      <collision_detector>bullet</collision_detector>\n    </dart>",
+                    1,
+                )
+            patched_block = patched_block.replace(dart_match.group(0), dart_block, 1)
+        else:
+            patched_block = patched_block.replace(
+                "</physics>",
+                "\n    <dart>\n      <collision_detector>bullet</collision_detector>\n    </dart>\n  </physics>",
+                1,
+            )
+
+        return text.replace(physics_block, patched_block, 1)
+
+    world_text = _force_dart_bullet_physics(world_text)
+
+    def _set_or_insert(block: str, tag: str, value: str) -> str:
+        if re.search(rf"<{tag}>[^<]*</{tag}>", block):
+            return re.sub(rf"<{tag}>[^<]*</{tag}>", f"<{tag}>{value}</{tag}>", block, count=1)
+        return block.replace("</physics>", f"\n    <{tag}>{value}</{tag}>\n  </physics>", 1)
+
+    physics_match = re.search(r"<physics[^>]*>.*?</physics>", world_text, flags=re.DOTALL)
+    if physics_match is not None:
+        physics_block = physics_match.group(0)
+        patched_block = physics_block
+        patched_block = re.sub(r'type="[^"]+"', 'type="dart"', patched_block, count=1)
+        # Keep simulation pacing consistent across robot/world/headless/GUI modes.
+        patched_block = _set_or_insert(patched_block, "max_step_size", "0.001")
+        patched_block = _set_or_insert(patched_block, "real_time_update_rate", "1000")
+        patched_block = _set_or_insert(patched_block, "real_time_factor", "1.0")
+
+        patched_block = re.sub(r"\s*<ode>.*?</ode>", "", patched_block, flags=re.DOTALL)
+
+        dart_match = re.search(r"<dart>.*?</dart>", patched_block, flags=re.DOTALL)
+        if dart_match is not None:
+            dart_block = dart_match.group(0)
+            if "<collision_detector>" in dart_block:
+                dart_block = re.sub(
+                    r"<collision_detector>[^<]+</collision_detector>",
+                    "<collision_detector>bullet</collision_detector>",
+                    dart_block,
+                    count=1,
+                )
+            else:
+                dart_block = dart_block.replace(
+                    "</dart>",
+                    "\n      <collision_detector>bullet</collision_detector>\n    </dart>",
+                    1,
+                )
+            patched_block = patched_block.replace(dart_match.group(0), dart_block, 1)
+        else:
+            patched_block = patched_block.replace(
+                "</physics>",
+                "\n    <dart>\n"
+                "      <collision_detector>bullet</collision_detector>\n"
+                "    </dart>\n"
+                "  </physics>",
+                1,
+            )
+
+        world_text = world_text.replace(physics_block, patched_block, 1)
+
+    required_plugins = [
+        ("gz::sim::systems::Physics", "gz-sim-physics-system", None),
+        ("gz::sim::systems::UserCommands", "gz-sim-user-commands-system", None),
+        ("gz::sim::systems::SceneBroadcaster", "gz-sim-scene-broadcaster-system", None),
+        ("gz::sim::systems::Sensors", "gz-sim-sensors-system", "<render_engine>ogre2</render_engine>"),
+        ("gz::sim::systems::Imu", "gz-sim-imu-system", None),
+    ]
+
+    blocks_to_add: list[str] = []
+    for system_name, filename, inner_xml in required_plugins:
+        if system_name in world_text:
+            continue
+        if inner_xml is None:
+            blocks_to_add.append(
+                f"\n    <plugin filename=\"{filename}\" name=\"{system_name}\">\n    </plugin>\n"
+            )
+        else:
+            blocks_to_add.append(
+                f"\n    <plugin filename=\"{filename}\" name=\"{system_name}\">\n"
+                f"      {inner_xml}\n"
+                "    </plugin>\n"
+            )
+
+    if not blocks_to_add:
+        return world_path
+
+    if blocks_to_add:
+        world_text = world_text.replace("</world>", "".join(blocks_to_add) + "</world>", 1)
+
+    fd, tmp_path = tempfile.mkstemp(prefix="world_with_required_plugins_", suffix=".world")
+    with os.fdopen(fd, "w", encoding="utf-8") as patched:
+        patched.write(world_text)
+    return tmp_path
+
+
+def _resolve_world_path(context, aws_root: Path | None) -> str:
+    world_path = LaunchConfiguration("warehouse_world").perform(context).strip()
+    if not world_path:
+        world_path = _default_warehouse_world_path()
+
+    if not world_path:
+        raise RuntimeError(
+            "No world path resolved. Pass warehouse_world:=<absolute-world-path> or install aws_robomaker_small_warehouse_world."
+        )
+
+    world_path = _rewrite_world_model_uris_to_file(
+        world_path=world_path,
+        enabled=LaunchConfiguration("rewrite_warehouse_model_uris_for_websocket").perform(context).lower() == "true",
+        aws_root=aws_root,
+    )
+    return _ensure_world_plugins(world_path)
+
+
+def _extract_world_name(world_path: str) -> str:
+    world_file = Path(world_path)
+    if not world_file.exists() or not world_file.is_file():
+        raise RuntimeError(f"World file does not exist: {world_path}")
+
+    world_text = world_file.read_text(encoding="utf-8")
+    match = re.search(r'<world[^>]*name=["\']([^"\']+)["\']', world_text)
+    if match is None:
+        raise RuntimeError(f"Unable to determine world name from: {world_path}")
+    return match.group(1)
+
+
+def _apply_camera_pose_to_gui_config(gui_config_path: str, camera_pose: str) -> str:
+    if not gui_config_path or not camera_pose:
+        return gui_config_path
+
+    cfg_path = Path(gui_config_path)
+    if not cfg_path.exists() or not cfg_path.is_file():
+        return gui_config_path
+
+    cfg_text = cfg_path.read_text(encoding="utf-8")
+    if "<camera_pose>" in cfg_text:
+        patched = re.sub(
+            r"<camera_pose>[^<]*</camera_pose>",
+            f"<camera_pose>{camera_pose}</camera_pose>",
+            cfg_text,
+            count=1,
+        )
+    elif "</plugin>" in cfg_text and 'plugin filename="MinimalScene"' in cfg_text:
+        patched = cfg_text.replace(
+            "</plugin>",
+            f"  <camera_pose>{camera_pose}</camera_pose>\n</plugin>",
+            1,
+        )
+    else:
+        return gui_config_path
+
+    fd, tmp_path = tempfile.mkstemp(prefix="gui_with_camera_pose_", suffix=".config")
+    with os.fdopen(fd, "w", encoding="utf-8") as patched_file:
+        patched_file.write(patched)
+    return tmp_path
+
+
+def _launch_setup(context, *args, **kwargs):
+    robot_type = LaunchConfiguration("robot_type").perform(context).strip().lower()
+    if robot_type not in {"jaka_kargo", "turtlebot3"}:
+        raise RuntimeError("robot_type must be 'jaka_kargo' or 'turtlebot3'")
+
+    ns = LaunchConfiguration("robot_namespace").perform(context).strip()
