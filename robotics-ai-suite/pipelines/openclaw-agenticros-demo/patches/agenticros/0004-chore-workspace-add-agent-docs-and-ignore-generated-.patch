-    if grep -q '"plugins"' "$OPENCLAW_JSON"; then
-      echo "Add \"allow\": [\"agenticros\"] under plugins in $OPENCLAW_JSON if the plugin does not load."
+  if command -v jq &>/dev/null; then
+    TMP_JSON=$(mktemp)
+    JQ_FILTER='
+      .plugins = (.plugins // {}) |
+      .plugins.entries = (.plugins.entries // {}) |
+      .plugins.load = (.plugins.load // {}) |
+      .plugins.load.paths = (((.plugins.load.paths // []) + [$plugin_path]) | unique) |
+      .plugins.allow = (((.plugins.allow // []) + ["agenticros"]) | unique) |
+      .plugins.entries.agenticros = ((.plugins.entries.agenticros // {}) + {
+        "enabled": true
+      })
+    '
+
+    if [[ -n "$ROSBRIDGE_URL" ]]; then
+      JQ_FILTER="$JQ_FILTER | .plugins.entries.agenticros.config = ((.plugins.entries.agenticros.config // {}) | .rosbridge.url = \$rosbridge_url)"
     fi
-  fi
-  # Optional: write rosbridge URL and robot namespace into plugin config
-  # (OpenClaw may expect plugins.entries.agenticros.config)
-  if [[ -n "$ROSBRIDGE_URL" || -n "$ROBOT_NAMESPACE" ]]; then
-    echo "To set rosbridge URL or robot namespace, edit $OPENCLAW_JSON:"
+
+    if [[ -n "$ROBOT_NAMESPACE" ]]; then
+      JQ_FILTER="$JQ_FILTER | .plugins.entries.agenticros.config = ((.plugins.entries.agenticros.config // {}) | .robot.namespace = \$robot_namespace)"
+    fi
+
+    jq \
+      --arg plugin_path "$PLUGIN_DIR" \
+      --arg rosbridge_url "$ROSBRIDGE_URL" \
+      --arg robot_namespace "$ROBOT_NAMESPACE" \
+      "$JQ_FILTER" \
+      "$OPENCLAW_JSON" > "$TMP_JSON" && mv "$TMP_JSON" "$OPENCLAW_JSON"
+
+    echo "Configured plugins.load.paths + plugins.entries.agenticros.enabled in $OPENCLAW_JSON"
+    echo "Configured plugins.allow to include agenticros"
+    [[ -n "$ROSBRIDGE_URL" ]]   && echo "Configured rosbridge URL: $ROSBRIDGE_URL"
+    [[ -n "$ROBOT_NAMESPACE" ]] && echo "Configured robot namespace: $ROBOT_NAMESPACE"
+  else
+    echo "jq not found; please edit $OPENCLAW_JSON manually:"
+    echo "  plugins.allow += [\"agenticros\"]"
+    echo "  plugins.load.paths += [\"$PLUGIN_DIR\"]"
+    echo "  plugins.entries.agenticros.enabled = true"
     [[ -n "$ROSBRIDGE_URL" ]]   && echo "  plugins.entries.agenticros.config.rosbridge.url = $ROSBRIDGE_URL"
     [[ -n "$ROBOT_NAMESPACE" ]] && echo "  plugins.entries.agenticros.config.robot.namespace = $ROBOT_NAMESPACE"
