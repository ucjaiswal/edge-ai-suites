# PostgreSQL
PG_USER=vms
PG_PASSWORD=changeme
PG_HOST=postgres
PG_PORT=5434

# Frigate
FRIGATE_HOST=host.docker.internal
FRIGATE_RECORDINGS_PATH=/tmp/frigate-recordings

# Nx Witness
NX_BASE_URL=https://<nx-witness-ip>:7001
NX_HOST=<nx-witness-ip>
NX_USERNAME=admin
NX_PASSWORD=changeme
NX_TLS_VERIFY=false
# Optional: path inside vms-backend container when NX_TLS_VERIFY=true
NX_CA_BUNDLE=
NX_RECORDINGS_PATH=/tmp/nx-recordings

# Live Video Captioning Analytics App
# FastAPI backend of the LVC stack (default port 4173)
LVC_HOST=host.docker.internal
LVC_BASE_URL=http://host.docker.internal:4173
# MediaMTX WebRTC signaling server (default port 8889)
MEDIAMTX_URL=http://host.docker.internal:8889

# DLS Vision App
DLS_VISION_HOST=host.docker.internal
DLS_VISION_PORT=443
DLS_VISION_TLS_VERIFY=false
# Optional: path inside vms-backend container when DLS_VISION_TLS_VERIFY=true
DLS_VISION_CA_BUNDLE=

# Ports
UI_HTTPS_PORT=3443

# TLS Certificates for UI (optional)
# By default, a self-signed certificate is auto-generated on startup.
# To use your own certificates, copy docker-compose.tls.yml to
# docker-compose.override.yml and place cert.pem + key.pem in ./certs/ui/.

# VMS Plugin API
VMS_PLUGIN_API_KEY=

# MQTT Broker (eclipse-mosquitto in the LVC stack, port 1883)
MQTT_BROKER_HOST=host.docker.internal
MQTT_BROKER_PORT=1883

# DLS Vision App MQTT — broker address as seen by VAP (for subscribing)
MQTT_HOST=host.docker.internal
MQTT_PORT=1883

# PIPELINE_SERVER_MQTT_HOST — address as seen by the DLStreamer Pipeline Server
# container inside the analytics app Docker network.
# The GStreamer Paho C MQTT client cannot resolve Docker service names across networks.
# The most reliable value is the host machine's LAN IP address, because port 1883
# is published from the mqtt-broker container to the host.
# DO NOT use 172.18.0.1 unless you have verified it is the gateway of the exact
# Docker network that the analytics app containers use. Use the host's LAN IP instead.
#   Find your host LAN IP: hostname -I | awk '{print $1}'
PIPELINE_SERVER_MQTT_HOST=<HOST_LAN_IP>
PIPELINE_SERVER_MQTT_PORT=1883
